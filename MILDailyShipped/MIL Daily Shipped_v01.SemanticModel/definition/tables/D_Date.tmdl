	partition D_Date-084985c0-f4ae-45d1-8b1f-959cd493cccd = calculated
		mode: import
		source =
				filter(ADDCOLUMNS(
				CALENDAR(today()-360,DATE(2038, 12, 31)),
				"Year",YEAR([Date]),
				"Month",Month([Date]),
				"Day", day([Date]),
				"Week", WEEKDAY([Date],1),
				"WeekN", WEEKNUM([Date],2),
				"Quarter",YEAR([Date])&"Q"&QUARTER([Date]),
				"YearMonth",year([Date])*100+MONTH([Date]),
				"YearWeek", year([Date])*100+WEEKNUM([Date],2)),[Date]<=TODAY())

	annotation PBI_Id = a3a38ec1702948b9aaffdf14956bc00d

