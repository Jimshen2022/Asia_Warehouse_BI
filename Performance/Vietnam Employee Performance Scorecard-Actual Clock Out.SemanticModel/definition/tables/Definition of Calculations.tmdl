	partition 'Definition of Calculations' = m
		mode: import
		source = ```
				let
				    Source = Table.FromRows(Json.Document(Binary.Decompress(Binary.FromText("", BinaryEncoding.Base64), Compression.Deflate)), let _t = ((type nullable text) meta [Serialized.Text = true]) in type table [Measure = _t, #"Definition of Calculation" = _t]),
				    #"Changed Type" = Table.TransformColumnTypes(Source,{{"Measure", type text}, {"Definition of Calculation", type text}}),
				    
				    // 假设 End of Day 和 Start of Day 都是你手动追加的行
				    #"Added Custom Rows" = Table.InsertRows(#"Changed Type", Table.RowCount(#"Changed Type"), {
				        [Measure = "End of Day", #"Definition of Calculation" = "If < 30 mins: Green, If 30-60 mins: Yellow, If > 60 mins: Red"],
				        [Measure = "Start of Day", #"Definition of Calculation" = "If < 30 mins: Green, If 30-60 mins: Yellow, If > 60 mins: Red"]
				    }),
				    
				    // --- 下面是实现“强制置底”的魔法 ---
				    
				    // 1. 添加临时排序列：遇到 Start/End of Day 赋值 2，其他赋值 1
				    #"Added Sort Helper" = Table.AddColumn(#"Added Custom Rows", "SortOrder", each if [Measure] = "Start of Day" or [Measure] = "End of Day" then 2 else 1),
				    
				    // 2. 双重排序：先按临时列排序 (1在上，2垫底)，然后再按 Measure 字母排序
				    #"Sorted Rows" = Table.Sort(#"Added Sort Helper",{{"SortOrder", Order.Ascending}, {"Measure", Order.Ascending}})
				in
				    #"Sorted Rows"
				```

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigation

