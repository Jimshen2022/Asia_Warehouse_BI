	partition 'Start/End of Day' = m
		mode: import
		source =
				let
				    Source = Sql.Database("ashley-edw.database.windows.net", "ASHLEY_EDW", [Query="DECLARE @wh_id_list AS VARCHAR(500);#(lf)#(lf)SET @wh_id_list = '335, 35'; --both warehoueses are Vietnam, local time is 12 hours ahead #(lf)#(lf)SELECT #(lf)t3.wh_id#(lf),t3.employee_id#(lf),t3.work_day#(lf),t3.clock_in#(lf),t3.clock_out#(lf),t3.first_tran_date_time#(lf),t3.last_tran_date_time#(lf),t3.first_tran_type#(lf),t3.first_tran_description#(lf),t3.last_tran_type#(lf),t3.last_tran_description#(lf),t3.time_before_first_tran_minutes#(lf),t3.time_after_last_tran_minutes#(lf)#(lf)FROM#(lf)(#(lf)SELECT t2.*, tranlog_start.tran_type first_tran_type, tranlog_start.description first_tran_description, #(lf)tranlog_end.tran_type last_tran_type, tranlog_end.description last_tran_description, #(lf)#(lf)DATEDIFF(MINUTE, clock_in, first_tran_date_time) AS time_before_first_tran_minutes, #(lf)DATEDIFF(MINUTE, last_tran_date_time, clock_out) AS time_after_last_tran_minutes#(lf), ROW_NUMBER() OVER (PARTITION BY t2.employee_id, t2.wh_id, t2.work_day ORDER BY t2.employee_id) row_number_rank#(lf)FROM#(lf)(#(lf)#(lf)SELECT T1.wh_id#(lf)     , employee_id#(lf)     , l.[work_day]#(lf)     , l.clock_in#(lf)     , l.clock_out#(lf)#(tab) , MIN(start_tran_date_time) first_tran_date_time #(lf)#(tab) , MAX(end_tran_date_time) last_tran_date_time#(lf)#(tab) #(lf)#(tab) #(lf)FROM#(lf)(#(lf)        SELECT wh_id#(lf)             , employee_id#(lf)             , item_number#(lf)             , start_tran_date#(lf)             , start_tran_time#(lf)             , end_tran_date#(lf)             , end_tran_time#(lf)             , hu_id#(lf)             , tran_qty#(lf)             , tran_type#(lf)             , description#(lf)             , CONCAT(CAST([start_tran_date] AS DATE), ' ', CAST([start_tran_time] AS TIME)) AS start_tran_date_time#(lf)             , CONCAT(CAST([end_tran_date] AS DATE), ' ', CAST([end_tran_time] AS TIME))     AS end_tran_date_time#(lf)        FROM [PowerBI_Distribution].[TranLog]#(lf)        WHERE CAST([start_tran_date] AS DATE)#(lf)              BETWEEN DATEADD(   DAY, -15, #(lf)                                               #(lf)                                                   CAST(DATEADD(HOUR, 7, GETUTCDATE()) AS DATE)#(lf)                                           #(lf)                             ) AND DATEADD(   DAY, 1, #(lf)                                                              CAST(DATEADD(HOUR, 7, GETUTCDATE()) AS DATE)#(lf)                                                      #(lf)                                          )#(lf)              AND [wh_id] IN#(lf)                  (#(lf)                      SELECT trim(value)FROM string_split(@wh_id_list, ',')#(lf)              #(lf)                  )#(lf)        AND [tran_type] <> '100'#(lf))     t1#(lf)    LEFT JOIN#(lf)    (#(lf)        SELECT DISTINCT#(lf)               t.[work_day]#(lf)             , t.WhseEmpNumber#(lf)             , t.EmployeeNumber#(lf)             , t.EmployeeName#(lf)             , t.[home_department]#(lf)             , t.home_wh_id#(lf)             , MIN(t.clock_in)  clock_in#(lf)             , MAX(t.clock_out) clock_out#(lf)             , MAX(t.[End Time])       [End Time]#(lf)        FROM#(lf)        (#(lf)            SELECT [cico_key]#(lf)                 , [wh_id]#(lf)                 , b.WarehouseID#(lf)                 , a.home_wh_id#(lf)                 , [work_day]#(lf)                 , [work_shift_id]#(lf)                 , [employee_id]#(lf)                 , b.WhseEmpNumber#(lf)                 , b.EmployeeNumber#(lf)                 , b.EmployeeName#(lf)                 , [clock_in]#(lf)                 , [actual_clock_out] AS [_clock_out] -- by crystal#(lf)                , DATEADD(MINUTE, #(lf)                    DATEDIFF(MINUTE, '00:00:00', CAST([actual_clock_out] AS TIME)) / 15 * 15,#(lf)                    CAST(CAST([actual_clock_out] AS DATE) AS DATETIME)#(lf)                     ) AS [clock_out] -- Aug.24.2024 - to round the clock out time to the nearest 15 minutes by Jim,Shen #(lf)                 , CASE#(lf)                       WHEN a.clock_out <> '' THEN#(lf)                           a.actual_clock_out#(lf)                       ELSE#(lf)                           DATEADD(HOUR, 7, GETUTCDATE())#(lf)                   END                                    AS [End Time]#(lf)                 , [supervisor_nbr]#(lf)                 , [home_supervisor_nbr]#(lf)                 , [group_nbr]#(lf)                 , [home_group_nbr]#(lf)                 , [department]#(lf)                 , [home_department]#(lf)            FROM [PowerBI_Distribution].[EmployeeClockInOut] a#(lf)                LEFT JOIN [PowerBI_Distribution].[DimEmployee]                        b#(lf)                    ON a.employee_id = b.EmployeeID#(lf)                       AND a.home_wh_id = b.WarehouseID#(lf)            WHERE CAST([work_day] AS DATE)#(lf)                  BETWEEN DATEADD(   DAY, -15, #(lf)                                                       CAST(DATEADD(HOUR, 7, GETUTCDATE()) AS DATE)#(lf)                                               #(lf)                                 ) AND #(lf)                                               CAST(DATEADD(HOUR, 7, GETUTCDATE()) AS DATE)#(lf)                                       #(lf)#(lf)                  AND [home_wh_id] IN#(lf)                      (#(lf)                          SELECT trim(value)FROM string_split(@wh_id_list, ',')#(lf)                      )#(lf)        ) t#(lf)        GROUP BY t.work_day#(lf)               , t.WhseEmpNumber#(lf)               , t.EmployeeNumber#(lf)               , t.EmployeeName#(lf)               , t.home_department#(lf)               , t.home_wh_id#(lf)#(lf)    ) l#(lf)        ON T1.[employee_id] = l.EmployeeNumber#(lf)           AND T1.[wh_id] = l.home_wh_id#(lf)WHERE#(lf)#(lf)    T1.end_tran_date_time >= l.clock_in#(lf)    AND T1.end_tran_date_time <= CASE WHEN l.clock_out <> '' THEN l.clock_out ELSE [End Time] END#(lf)    AND T1.start_tran_date_time >= l.clock_in#(lf)    AND T1.start_tran_date_time <= CASE WHEN l.clock_out <> '' THEN l.clock_out ELSE [End Time] END#(lf)    AND l.clock_in IS NOT NULL#(lf)    AND l.clock_out IS NOT NULL#(lf)#(tab)AND DATEDIFF(Hour, l.clock_in, l.clock_out) < 24#(lf)GROUP BY#(lf)        t1.wh_id,#(lf)        t1.employee_id#(lf)       , l.work_day#(lf)       , l.clock_in#(lf)       , l.clock_out#(lf)#(tab)   ) t2#(lf)#(lf)#(tab)   LEFT JOIN [PowerBI_Distribution].[TranLog] tranlog_start#(lf)#(tab)   ON t2.first_tran_date_time =  CONCAT(CAST(tranlog_start.[start_tran_date] AS DATE), ' ', CAST(tranlog_start.[start_tran_time] AS TIME))#(lf)#(tab)   and t2.employee_id = tranlog_start.employee_id#(lf)#(tab)   AND t2.wh_id = tranlog_start.wh_id#(lf)#(lf)#(tab)   LEFT JOIN [PowerBI_Distribution].[TranLog] tranlog_end#(lf)#(tab)   ON t2.last_tran_date_time =   CONCAT(CAST(tranlog_end.[end_tran_date] AS DATE), ' ', CAST(tranlog_end.[end_tran_time] AS TIME))#(lf)#(tab)    and t2.employee_id = tranlog_end.employee_id#(lf)#(tab)#(tab)AND t2.wh_id = tranlog_end.wh_id#(lf)) t3#(lf)#(lf)WHERE row_number_rank = 1", CreateNavigationProperties=false, CommandTimeout=#duration(0, 2, 40, 0)]),
				    #"Changed Type" = Table.TransformColumnTypes(Source,{{"work_day", type date}}),
				    #"Inserted Merged Column" = Table.AddColumn(#"Changed Type", "Master Key", each Text.Combine({[wh_id], [employee_id], Text.From([work_day], "en-US")}, "-"), type text),
				    #"Changed Type1" = Table.TransformColumnTypes(#"Inserted Merged Column",{{"first_tran_date_time", type datetime}, {"last_tran_date_time", type datetime}}),
				    #"Renamed Columns" = Table.RenameColumns(#"Changed Type1",{{"first_tran_date_time", "Start of Day Tran Date/Time"}, {"last_tran_date_time", "End of Day Tran Date/Time"}, {"first_tran_type", "Start of Day Tran Type"}, {"first_tran_description", "Start of Day Tran Description"}, {"last_tran_type", "End of Day Tran Type"}, {"last_tran_description", "End of Day Tran Description"}, {"time_before_first_tran_minutes", "Start of Day time"}, {"time_after_last_tran_minutes", "End of Day time"}})
				in
				    #"Renamed Columns"

	annotation PBI_ResultType = Exception

