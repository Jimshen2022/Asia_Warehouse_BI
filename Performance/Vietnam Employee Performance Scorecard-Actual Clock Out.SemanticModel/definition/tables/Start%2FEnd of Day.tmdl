table 'Start/End of Day'
	lineageTag: 3895f027-4cb9-4c03-af38-ae35c6dc4079

	measure 'Start of Day' =
			
			
			VAR StartofDay=
			CALCULATE(AVERAGE('Start/End of Day'[Start of Day time]))
			
			VAR Startofdaybyee = AVERAGEX(VALUES('Clock In Clock Out'[Employee Name]),StartofDay)
			
			VAR startofdaybyworkday = AVERAGEX(VALUES('Clock In Clock Out'[Work Day]),Startofdaybyee)
			
			Return
			startofdaybyworkday
		formatString: 0
		lineageTag: 9a30d2a7-56f4-4457-97eb-3300cd64a928

	measure 'End of Day' =
			
			
			VAR EndofDay=
			CALCULATE(AVERAGE('Start/End of Day'[End of Day time]))
			
			VAR Endofdaybyee = AVERAGEX(VALUES('Clock In Clock Out'[EE Number]),EndofDay)
			
			VAR endofdaybyworkday = AVERAGEX(VALUES('Clock In Clock Out'[Work Day]),Endofdaybyee)
			
			Return
			endofdaybyworkday
		formatString: #,0
		lineageTag: aab0641f-b174-4a77-b0f0-e82a3255347d

