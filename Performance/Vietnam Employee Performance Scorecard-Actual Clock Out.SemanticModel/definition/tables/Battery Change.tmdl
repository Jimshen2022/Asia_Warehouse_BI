	partition 'Battery Change' = m
		mode: import
		source =
				let
				    Source = Sql.Database("ashley-edw.database.windows.net", "ASHLEY_EDW", [Query="SELECT [tran_type]#(lf)      ,[description]#(lf)      ,[start_tran_date]#(lf)      ,[start_tran_time]#(lf)      ,[end_tran_date]#(lf)      ,[end_tran_time]#(lf)      ,[employee_id]#(lf)      ,[control_number]#(lf)      ,[control_number_2]#(lf)      ,[wh_id]#(lf)      ,[location_id]#(lf)      ,[elapsed_time]#(lf)#(tab)  ,CAST(DATEDIFF(SECOND,start_tran_time, end_tran_time) / 60.00 AS FLOAT) AS spent_time_minutes#(lf)  FROM [PowerBI_Distribution].[TranLog]#(lf)  where [wh_id] IN ('35','335')#(lf)  and [tran_type]='500'#(lf)  order by start_tran_date asc", CreateNavigationProperties=false, CommandTimeout=#duration(0, 2, 40, 0)]),
				    #"Changed Type" = Table.TransformColumnTypes(Source,{{"start_tran_date", type date}, {"end_tran_date", type date}}),
				    #"Inserted Merged Column" = Table.AddColumn(#"Changed Type", "Master Key", each Text.Combine({[wh_id], [employee_id], Text.From([start_tran_date], "en-US")}, "-"), type text)
				in
				    #"Inserted Merged Column"

	annotation PBI_ResultType = Table

