table 'Battery Change'
	lineageTag: c835fb5d-763c-453a-8923-477dac485975

	measure '# of Battery Changes' = COUNT('Battery Change'[description])
		formatString: 0
		lineageTag: 14bdb55c-d233-4b10-b0bd-1b1056bc8fd6

	measure 'Avg Minutes of Battery Change' =
			
			
			VAR BatteryChangeTime=
			CALCULATE(AVERAGE('Battery Change'[spent_time_minutes]))
			
			VAR Batterychangebyee = AVERAGEX(VALUES('Clock In Clock Out'[Employee Name]),BatteryChangeTime)
			
			VAR Batterychangebyworkday = AVERAGEX(VALUES('Clock In Clock Out'[Work Day]),Batterychangebyee)
			
			Return
			Batterychangebyworkday
		lineageTag: 50d1893e-de4a-420d-acda-6c219484de60

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Minutes of Battery Change' = ```
			
			
			sum('Battery Change'[spent_time_minutes])
			
			```
		lineageTag: 081e468c-46eb-4e22-89d8-a49e205ab95f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

