	partition 'Indirect History' = m
		mode: import
		source =
				let
				    Source = Sql.Database("ashley-edw.database.windows.net", "ASHLEY_EDW", [Query="SELECT  [Name]#(lf)      ,[EmployeeID]#(lf)      ,[EmployeeNumber]#(lf)      ,[WarehouseID]#(lf)      ,[WorkDay]#(lf)      ,[ActivityDescription]#(lf)      ,[Duration]#(lf)      ,[ProcessStart]#(lf)      ,[ProcessEnd]#(lf)      ,[ClockIn]#(lf)      ,[ClockOut]#(lf)      ,[Supervisor]#(lf)      ,[Source]#(lf)      ,[ProcessCode]#(lf)  FROM [PowerBI_Distribution].[IndirectHistory]#(lf)  where cast ([workday] as date)>DATEADD(DAY, -15, GETDATE())#(lf)  and [WarehouseID] IN ('335','35')", CreateNavigationProperties=false, CommandTimeout=#duration(0, 2, 40, 0)]),
				    #"Changed Type" = Table.TransformColumnTypes(Source,{{"WorkDay", type date}}),
				    #"Inserted Merged Column" = Table.AddColumn(#"Changed Type", "Key", each Text.Combine({[WarehouseID], [EmployeeNumber], Text.From([WorkDay], "en-US")}, "-"), type text),
				    #"Added Conditional Column" = Table.AddColumn(#"Inserted Merged Column", "Approved or Rejected", each if [ProcessCode] = "REJECTED" then "REJECTED" else "APPROVED"),
				    #"Inserted First Characters" = Table.AddColumn(#"Added Conditional Column", "First Characters", each Text.Start([ActivityDescription], 4), type text),
				    #"Renamed Columns" = Table.RenameColumns(#"Inserted First Characters",{{"First Characters", "Activity Code"}})
				in
				    #"Renamed Columns"

	annotation PBI_ResultType = Exception

