	column Approver = IF('Indirect History'[Source] IN {"WA MESSAGE","YA MESSAGE"}, 'Indirect History'[Supervisor],'Indirect History'[Source])
		lineageTag: 90f4d465-dfe9-4840-b06b-a01b6d3d60da
		summarizeBy: none

