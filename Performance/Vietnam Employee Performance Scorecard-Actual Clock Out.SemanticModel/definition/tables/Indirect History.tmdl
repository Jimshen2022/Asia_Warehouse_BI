	measure 'Battery Change Time Approved' =
			
			
			VAR BatteryChangeTimeApproved=
			CALCULATE(AVERAGE('Indirect History'[Duration]),FILTER('Indirect History','Indirect History'[Activity Code]="I104"),FILTER('Indirect History','Indirect History'[Approved or Rejected]="Approved"))
			
			VAR Batterychangebyee = AVERAGEX(VALUES('Clock In Clock Out'[Employee Name]),BatteryChangeTimeApproved)
			
			VAR Batterychangebyworkday = AVERAGEX(VALUES('Clock In Clock Out'[Work Day]),Batterychangebyee)
			
			Return
			Batterychangebyworkday
		formatString: 0.00
		lineageTag: f538dff1-418a-482e-a4d8-eb0186117728

	measure 'Battery Change Time Rejected' =
			
			
			VAR BatteryChangeTimeRejected=
			CALCULATE(AVERAGE('Indirect History'[Duration]),FILTER('Indirect History','Indirect History'[Activity Code]="I104"),FILTER('Indirect History','Indirect History'[Approved or Rejected]="Rejected"))
			
			VAR Batterychangebyee = AVERAGEX(VALUES('Clock In Clock Out'[Employee Name]),BatteryChangeTimeRejected)
			
			VAR Batterychangebyworkday = AVERAGEX(VALUES('Clock In Clock Out'[Work Day]),Batterychangebyee)
			
			Return
			Batterychangebyworkday
		formatString: 0.00
		lineageTag: ecd0ea9b-9a12-4032-ae51-c798ec07b518

	measure '# of Battery Changes Rejected' = CALCULATE(COUNT('Indirect History'[Activity Code]),FILTER('Indirect History','Indirect History'[Activity Code]="I104"),FILTER('Indirect History','Indirect History'[Approved or Rejected]="Rejected"))
		formatString: 0
