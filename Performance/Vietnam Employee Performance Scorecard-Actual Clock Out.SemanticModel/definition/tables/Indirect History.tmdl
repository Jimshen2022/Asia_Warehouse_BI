	measure 'Meeting Time' =
			
			
			VAR Meetingtime=
			CALCULATE(sum('Indirect History'[Duration]),FILTER('Indirect History','Indirect History'[Activity Code]="I101"))
			
			VAR meetingtimebyee = AVERAGEX(VALUES('Clock In Clock Out'[Employee Name]),Meetingtime)
			
			VAR meetingtimebyworkday = AVERAGEX(VALUES('Clock In Clock Out'[Work Day]),meetingtimebyee)
			
			Return
			meetingtimebyworkday
