	partition 'Summed Process Report' = m
		mode: import
		source =
				let
				    Source = Sql.Database("ashley-edw.database.windows.net", "ASHLEY_EDW", [Query="SELECT#(lf)     a.[wh_id]#(lf)    ,b.[EmployeeName]#(lf)    ,b.[EmployeeNumber]#(lf)    ,a.[process_transaction]#(lf)    ,CAST(a.[work_day] AS DATE)                              AS [work_day]#(lf)    ,COUNT(a.[process_id])                                   AS total_transactions#(lf)    ,SUM(a.[total_sam])                                      AS Total_SAM_MINS#(lf)    ,a.[labor_type]#(lf)    ,a.[process_id]#(lf)    ,c.process_code#(lf)    ,SUM(#(lf)        CASE#(lf)            WHEN c.process_code LIKE 'LUNCH-OVER%'#(lf)             AND DATEPART(HOUR, a.process_start) >= 7#(lf)             AND DATEPART(HOUR, a.process_start) <  16#(lf)            THEN CASE#(lf)                    WHEN a.actual_elapsed_time - 15 < 0 THEN 0#(lf)                    ELSE a.actual_elapsed_time - 15#(lf)                 END#(lf)            ELSE a.actual_elapsed_time#(lf)        END#(lf)     )                                                       AS total_mins#(lf)    ,MIN(a.process_start)                                    AS process_start_min#(lf)    ,MAX(a.process_end)                                      AS process_end_max#(lf)#(lf)FROM [Distribution_Warehouse_Wholesale].[ProcessReport]         a#(lf)    LEFT JOIN [PowerBI_Distribution].[DimEmployee]              b#(lf)           ON a.[employee_id]  = b.[EmployeeID]#(lf)          AND a.[wh_id]        = b.[WarehouseID]#(lf)    LEFT JOIN [Distribution_Warehouse_Wholesale].[t_la_process] c#(lf)           ON a.[process_id]   = c.[process_id]#(lf)          AND a.[wh_id]        = c.[wh_id]#(lf)#(lf)WHERE a.[wh_id] IN ('335','35')#(lf)  AND  a.[work_day]    >  DATEADD(DAY, -15, GETDATE())#(lf)  AND  a.[application] =  'WA'#(lf)#(lf)GROUP BY#(lf)     a.[wh_id]#(lf)    ,b.[EmployeeName]#(lf)    ,b.[EmployeeNumber]#(lf)    ,a.[process_transaction]#(lf)    ,CAST(a.[work_day] AS DATE)#(lf)    ,a.[labor_type]#(lf)    ,a.[process_id]#(lf)    ,c.[process_code]", CreateNavigationProperties=false, CommandTimeout=#duration(0, 2, 40, 0)]),
				    #"Added Custom" = Table.AddColumn(Source, "WhseEmployee", each [wh_id]&"-"&[EmployeeNumber]),
				    #"Added Conditional Column" = Table.AddColumn(#"Added Custom", "Flag", each if [wh_id] = "5" then "Yes" else if [wh_id] = "42" then "Yes" else "No")
				in
				    #"Added Conditional Column"

	annotation PBI_ResultType = Exception

	annotation PBI_NavigationStepName = Navigation

