	measure 'Overall TTIW all' = IF([TTIW minutes]<300,[TTIW minutes]-[Lunch Mins],[TTIW minutes])
		lineageTag: 25c33a21-2a69-484e-b3cb-3c7eafafd476

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Lost Time Mins' = if (([Overall TTIW for lost time calc]-[Direct Time Mins]-[Non Performance Time Mins]-[Indirect Time Mins])=[Overall TTIW all],BLANK(),[Overall TTIW for lost time calc]-[Direct Time Mins]-[Non Performance Time Mins]-[Indirect Time Mins])
		lineageTag: a0adad15-d2d3-4d16-b21e-1a1f0b271d4e

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Direct %' = [Direct Time Mins]/[Overall TTIW all]
