	partition GAP = m
		mode: import
		source =
				let
				    Source = Sql.Database("ashley-edw.database.windows.net", "ASHLEY_EDW", [Query="  SELECT [Tran Type]#(lf)      ,[Tran Descript]#(lf)      ,[EE Name]#(lf)      ,[EE Number]#(lf)      ,[Start Trans Datetime]#(lf)      ,[End Trans Datetime]#(lf)      ,[Supervisor Name]#(lf)      ,[Department]#(lf)      ,[Warehouse #]#(lf)      ,[Date]#(lf)      ,[Transaction Qty]#(lf)      ,[WorkDay] AS [work_day]#(lf)      ,[Start Tran Date] AS [start_tran_date] #(lf)      ,[Start Tran Time] AS [start_tran_time] #(lf)      ,[End Tran Date] AS [end_tran_date]#(lf)      ,[End Tran Time] AS [end_tran_time]#(lf)      ,[COUNT]#(lf)      ,[GapTime] AS [Gap_Time]#(lf)      ,[ElapsedTime] AS [Elapsed_Time]#(lf)      ,[WorkTypeKey]#(lf)  FROM [PowerBI_Distribution].[GapTimeReport_EmployeeDetail]#(lf)  where [Warehouse #] IN ('335','35')", CreateNavigationProperties=false, CommandTimeout=#duration(0, 2, 40, 0)]),
				    #"Changed Type" = Table.TransformColumnTypes(Source,{{"Start Trans Datetime", type datetime}, {"End Trans Datetime", type datetime}}),
				    #"Added Custom" = Table.AddColumn(#"Changed Type", "Today", each DateTime.FixedLocalNow()),
				    #"Changed Type1" = Table.TransformColumnTypes(#"Added Custom",{{"Date", type date}}),
				    #"Inserted Merged Column" = Table.AddColumn(#"Changed Type1", "EE Key GapTime", each Text.Combine({Text.From([Date], "en-US"), [#"Warehouse #"], [EE Number]}, " "), type text),
				    #"Extracted Text Before Delimiter" = Table.TransformColumns(#"Inserted Merged Column", {{"Department", each Text.BeforeDelimiter(_, "*"), type text}}),
				    #"Changed Type2" = Table.TransformColumnTypes(#"Extracted Text Before Delimiter",{{"work_day", type date}}),
				    #"Inserted Merged Column1" = Table.AddColumn(#"Changed Type2", "Master Key", each Text.Combine({[#"Warehouse #"], [EE Number], Text.From([work_day], "en-US")}, "-"), type text)
				in
				    #"Inserted Merged Column1"

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigation

