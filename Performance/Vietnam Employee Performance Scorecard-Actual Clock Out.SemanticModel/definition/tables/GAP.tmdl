table GAP
	lineageTag: e4b20c5b-9863-4ad6-897b-4578f4e24697

	measure 'Gap Time Hours' =
			
			VAR GapTimeMins =
			    CALCULATE (
			        SUM ( 'GAP'[Gap_Time] )
			    )                                                                                                                                                                                                                          VAR Breakmins =
			    CALCULATE (
			        SUM ( 'Summed Process Report'[total_mins] ),
			        'Summed Process Report'[process_code] ="BREAK"
			    )                                                                                                                                                                                                                          VAR Lunchmins =
			     CALCULATE(
			        SUM( 'Summed Process Report'[total_mins] ),
			        'Summed Process Report'[labor_type] ="UNP"
			)                                                                                                                                                                                                                VAR Gapminuslunchbreak =
			   GapTimeMins-Breakmins-LunchMins
			RETURN
			   IF(DIVIDE(Gapminuslunchbreak,60,0)<=0,BLANK(),DIVIDE(Gapminuslunchbreak,60,0))
		lineageTag: 8b197085-993a-4b22-94a3-acf8e76f1962

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Trans. per Hour' = DIVIDE([transactions],[ttiw hours],BLANK())
		lineageTag: 2ec882d7-e1a0-4654-b6de-5b9edb94e768

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Gap Time (Hrs)' = AVERAGEX(VALUES('Clock In Clock Out'[Work Day]),GAP[Gap Time Hours])
		formatString: 0.00
		lineageTag: 8d9564c5-9436-466b-876f-f45c7e5a2d56

	measure 'average gap' = AVERAGEX(VALUES('Clock In Clock Out'[Employee Name]),GAP[Gap Time (Hrs)])
		lineageTag: 80877c45-1565-4452-a116-92e9f986cc41

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Gap per EE' = GAP[Gap Time (Hrs)]/[Headcount v1]
		lineageTag: 53589db2-131b-4442-9883-813cfe3aa4bd

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Gap Time (Hrs) Final' = AVERAGEX(VALUES('Clock In Clock Out'[Employee Name]),GAP[Gap Time (Hrs)])
		lineageTag: 306ef126-820e-4ce6-ad53-d1cdc6c34863

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '# of Trans.' = SUM(GAP[Count])
		formatString: 0
		lineageTag: c350efb2-9278-4dc0-818e-bf2e89f39efc

	measure '# of Trans. Final' = AVERAGEX(VALUES('Clock In Clock Out'[Employee Name]),'GAP'[# of Trans.])
		formatString: 0
		lineageTag: 99abc76c-2113-497f-bded-d27719bc2765

	measure 'Trans. per Hour Final' = AVERAGEX(VALUES('Clock In Clock Out'[Employee Name]),GAP[Trans. per Hour])
		formatString: 0
		lineageTag: 4bdf23b6-116c-4e6e-985f-d36bbd9d84ac

	measure 'Trans. per Hour Weekly' = AVERAGEX(VALUES('Clock In Clock Out'[Work Day]),[Trans. per Hour Final])
		formatString: 0
		lineageTag: e8def6dd-4b2a-45f9-8020-36bc1003c413

	measure 'Gap time for detail' =
			
			VAR gaphours=
			SUM('GAP'[Gap_Time])/60
			
			VAR gaptotal=
			IF(gaphours<=0,BLANK(),gaphours)
			
			Return
			AVERAGEX(VALUES('Clock In Clock Out'[Work Day]),gaptotal)
		lineageTag: 5940bf59-206d-4bf4-b1e1-ba2bc52c864a

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure subtract = "-"
		lineageTag: fffc3199-21d9-4a98-9b0c-b68b85265a70

	measure equal = "="
		lineageTag: 37db6112-1857-4abc-9930-dbe732c11934

	measure 'subtract 2' = "-"
		lineageTag: c3351a8e-c2da-44bb-bf36-9c037978ea64

	measure transactions = SUM(GAP[COUNT])
		formatString: 0
		lineageTag: 2ccc92af-873c-4490-b432-2301ebacd48a

	measure 'ttiw hours' = DIVIDE([TTIW minutes],60,BLANK())
		lineageTag: 8135a0a3-05f9-4a0c-8349-1e6d5b7159a1

		annotation PBI_FormatHint = {"isGeneralNumber":true}

