	measure 'Ecomm F7 formatting' = IF([ECOMM F7 Exceptions]>=CALCULATE(Sum('Performance Goals'[Goal]),FILTER('Performance Goals','Performance Goals'[Measure]="F7 Ecomm Exceptions"))*[# of Days Worked],"#DE6A73")
