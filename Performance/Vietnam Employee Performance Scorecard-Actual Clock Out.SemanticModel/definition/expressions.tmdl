expression 'Start & End of Day' =
		let
		    Source = Sql.Database("ashley-edw.database.windows.net", "ASHLEY_EDW", [Query="select [work_day]#(lf)     , [wh_id]#(lf)     , [employee_id]#(lf)     , [First_Move]#(lf)     , [Last_Move]#(lf)     , process_start_id#(lf)     , process_start_name#(lf)     , process_start_code#(lf)     , process_end_id#(lf)     , process_end_name#(lf)     , process_end_code#(lf)     , [employeenumber]#(lf)     , [Clock_In]#(lf)     , [Clock_out]#(lf)from#(lf)(#(lf)    select p.[work_day]#(lf)         , p.[wh_id]#(lf)         , p.[employee_id]#(lf)         , p.[employeenumber]#(lf)         , p.EmployeeName#(lf)         , p.Clock_In#(lf)         , p.First_Move#(lf)         , p.Last_Move#(lf)         , p.process_start_id#(lf)         , p.process_start_name#(lf)         , p.process_start_code#(lf)         , p.process_end_id#(lf)         , p.process_end_name#(lf)         , p.process_end_code#(lf)         , p.Clock_out#(lf)         , datediff(minute, p.Clock_In, p.First_Move) as [start_min]#(lf)         , datediff(minute, p.Last_Move, p.Clock_out) as [end_min]#(lf)    from#(lf)    (#(lf)        select a.[work_day]#(lf)             , a.[wh_id]#(lf)             , a.[employee_id]#(lf)             , (a.[process_start]) as [First_Move]#(lf)             , (a.[process_end])   as [Last_Move]#(lf)             , a.process_start_id#(lf)             , a.process_start_name#(lf)             , a.process_start_code#(lf)             , a.process_end_id#(lf)             , a.process_end_name#(lf)             , a.process_end_code#(lf)             , a.[home_department]#(lf)             , a.[labor_type]#(lf)             , a.[employeenumber]#(lf)             , a.EmployeeName#(lf)             , (z.[c_in])          as Clock_In#(lf)             , (z.[c_out])         as Clock_out#(lf)        from#(lf)        (#(lf)            select distinct#(lf)                   t1.*#(lf)                 , t2.process_id   as process_start_id#(lf)                 , t3.process_id   as process_end_id#(lf)                 , t4.process_name as process_start_name#(lf)                 , t4.process_code as process_start_code#(lf)                 , t5.process_name as process_end_name#(lf)                 , t5.process_code as process_end_code#(lf)            from#(lf)            (#(lf)                select distinct#(lf)                       a.[work_day]#(lf)                     , a.[wh_id]#(lf)                     , a.[employee_id]#(lf)                     , min(a.[process_start]) as [process_start]#(lf)                     , max(a.[process_end])   as [process_end]#(lf)                     , a.[home_department]#(lf)                     , a.[labor_type]#(lf)                     , b.[EmployeeNumber]#(lf)                     , b.EmployeeName#(lf)                from [Distribution_Warehouse_Wholesale].[ProcessReport]          a#(lf)                    inner join [PowerBI_Distribution].[DimEmployee]              b#(lf)                        on CONCAT(a.wh_id, a.employee_id) = concat(b.warehouseid, b.employeeid)#(lf)                    inner join [Distribution_Warehouse_Wholesale].[t_la_process] c#(lf)                        on a.wh_id = c.wh_id#(lf)                           and a.process_id = c.process_id#(lf)                           and c.labor_type = 'DIR'#(lf)                where a.[work_day] > dateadd(day, -15, getdate())#(lf)                      and a.[labor_type] = 'DIR'#(lf)                      and a.type = 'I'#(lf)                      and process_code not in ( 'LOG ON', 'MENU', 'TRAVEL', 'BREAK-OVER', 'LUNCH-OVER', 'REJECTED' )#(lf)                group by a.[work_day]#(lf)                       , a.[wh_id]#(lf)                       , a.[employee_id]#(lf)                       , a.[home_department]#(lf)                       , a.[labor_type]#(lf)                       , b.[employeenumber]#(lf)                       , b.EmployeeName#(lf)            )                                                               t1 --main table giving minimum process start and maximum process end#(lf)                left join#(lf)                (#(lf)                    select a.*#(lf)                    from [Distribution_Warehouse_Wholesale].[ProcessReport]          a#(lf)                        inner join [Distribution_Warehouse_Wholesale].[t_la_process] c#(lf)                            on a.wh_id = c.wh_id#(lf)                               and a.process_id = c.process_id#(lf)                               and c.labor_type = 'DIR'#(lf)                    where a.[work_day] > dateadd(day, -15, getdate())#(lf)                          and a.[labor_type] = 'DIR'#(lf)                          and a.type = 'I'#(lf)                          and process_code not in ( 'LOG ON', 'MENU', 'TRAVEL', 'BREAK-OVER', 'LUNCH-OVER', 'REJECTED' )#(lf)                )                                                           t2 --table to get process start id. filtering conditions applied similar to table t1 in order to make sure similar subset is selected#(lf)                    on t1.wh_id = t2.wh_id#(lf)                       and t1.[employee_id] = t2.employee_id#(lf)                       and t1.[process_start] = t2.process_start#(lf)                       and t1.[home_department] = t2.home_department#(lf)                left join#(lf)                (#(lf)                    select a.*#(lf)                    from [Distribution_Warehouse_Wholesale].[ProcessReport]          a#(lf)                        inner join [Distribution_Warehouse_Wholesale].[t_la_process] c#(lf)                            on a.wh_id = c.wh_id#(lf)                               and a.process_id = c.process_id#(lf)                               and c.labor_type = 'DIR'#(lf)                    where a.[work_day] > dateadd(day, -15, getdate())#(lf)                          and a.[labor_type] = 'DIR'#(lf)                          and a.type = 'I'#(lf)                          and process_code not in ( 'LOG ON', 'MENU', 'TRAVEL', 'BREAK-OVER', 'LUNCH-OVER', 'REJECTED' )#(lf)                )                                                           t3 --table to get process end id. filtering conditions applied similar to table t1 in order to make sure similar subset is selected#(lf)                    on t1.wh_id = t3.wh_id#(lf)                       and t1.[employee_id] = t3.employee_id#(lf)                       and t1.[process_end] = t3.process_end#(lf)                       and t1.[home_department] = t3.home_department#(lf)                left join [Distribution_Warehouse_Wholesale].[t_la_process] t4 --table to get process start code and process start name related to process start id#(lf)                    on t2.wh_id = t4.wh_id#(lf)                       and t2.process_id = t4.process_id#(lf)                left join [Distribution_Warehouse_Wholesale].[t_la_process] t5 --table to get process start code and process start name related to process start id#(lf)                    on t3.wh_id = t5.wh_id#(lf)                       and t3.process_id = t5.process_id#(lf)#(lf)        --WHERE  t1.wh_id = '1' AND CAST(t1.work_day AS DATE) = '2023-09-01' AND t1.[employee_id] = '5749'#(lf)        --WHERE  t1.wh_id = '28' AND CAST(t1.work_day AS DATE) = '2023-09-01' AND t1.[employee_id] = '1057004'#(lf)#(lf)        )     a#(lf)            inner join#(lf)            (#(lf)                select [wh_id]#(lf)                     , [work_day]#(lf)                     , [home_department]#(lf)                     , min([clock_in])  as c_in#(lf)                     , max([clock_out]) as _c_out -- by crystal#(lf)                     , MAX(DATEADD(MINUTE, #(lf)                        DATEDIFF(MINUTE, '00:00:00', CAST([clock_out] AS TIME)) / 15 * 15,#(lf)                        CAST(CAST([clock_out] AS DATE) AS DATETIME)#(lf)                                )) AS [c_out] -- Aug.24.2024 - to round the clock out time to the nearest 15 minutes by Jim,Shen #(lf)                     , employee_id#(lf)                from [Distribution_Warehouse_Wholesale].[EmployeeClockInOut]#(lf)                where cast([work_day] as date)#(lf)                between dateadd(day, -15, getdate()) and getdate()#(lf)                group by [wh_id]#(lf)                       , [work_day]#(lf)                       , [home_department]#(lf)                       , employee_id#(lf)            ) z#(lf)                on a.[wh_id] = z.[wh_id]#(lf)                   and a.[employee_id] = z.employee_id#(lf)                   and cast(a.[work_day] as date) = cast(z.[work_day] as date)#(lf)        where cast(a.[work_day] as date)#(lf)              between dateadd(day, -15, getdate()) and getdate()#(lf)              and a.[wh_id] in ( '335','35' )#(lf)              --and a.[home_department] in ( '1322', '3619', '2642', '3345', '4402', '4005', '1344', '3613', '2634'#(lf)               --                          , '3316', '4403', '4003', '1448', '3646', '2664', '3366', '4460', '4015'#(lf)               --                          , '1364', '3719', '2637', '3335', '4404', '4072', '1421', '2627', '3338'#(lf)                --                         , '4438', '1443', '3642', '2662', '3364', '4457', '4024', '5512', '4915'#(lf)                 --                        , '4901', '4914', '4904', '4972', '4905', '4924', '4903','4450','1345','1369'#(lf)                --                         ,'1370','2608','2638','2640','3337','3341', '4028'#(lf)                 --                        )#(lf)    ) p#(lf)) t1;#(lf)", CreateNavigationProperties=false, CommandTimeout=#duration(0, 2, 40, 0)]),
		    #"Renamed Columns" = Table.RenameColumns(Source,{{"work_day", "Work Day"}}),
		    #"Changed Type" = Table.TransformColumnTypes(#"Renamed Columns",{{"Work Day", type date}}),
		    #"Renamed Columns1" = Table.RenameColumns(#"Changed Type",{{"wh_id", "WH_ID"}, {"employeenumber", "Employee #"}}),
		    #"Added Custom" = Table.AddColumn(#"Renamed Columns1", "WhseEmployee#", each [WH_ID]&"-"&[#"Employee #"])
		in
		    #"Added Custom"
	lineageTag: 1c2f5991-b99a-45b1-8bf6-3a0af44f362f

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

expression pph =
		let
		    Source = Sql.Database("ashley-edw.database.windows.net", "ASHLEY_EDW", [Query="--Date: 12/4/23#(lf)-- added clockin, clockout difference filter where clockout is after clockin to remove  bad data#(lf)#(lf)--Date: 11/30/23#(lf)-- added clockin, clockout difference filter of less than 24 hours to remove  bad data#(lf)#(lf)--Date: 11/29/23#(lf)-- update code and time calculation for warehouse 335, 35 (Vietnam)#(lf)--Date: 8/2/23#(lf)-- updated query with parameters#(lf)#(lf)--Date: 11/15/2022#(lf)-- removed worked days filter and added in the output#(lf)#(lf)--Date: 6/21/2022#(lf)--comment: Added tran type 114(production casegood receipts). It will have only casegood category. Added warehouse 70(EST time zone)#(lf)#(lf)--Date: 6/22/2022#(lf)--comment: Aggregated clock-in, clock out info for an employee on a work day as some employees having multiple clockins and clockout on same day due to lunch break being a clock out resulting in inflated PPH values (emp 138801)#(lf)#(lf)DECLARE @wh_id_list AS VARCHAR(500);#(lf)DECLARE @tran_list AS VARCHAR(500);#(lf)DECLARE @tran_list_withoutPickPut AS VARCHAR(500);#(lf)#(lf)#(lf)#(lf)SET @wh_id_list = '335, 35'; --both warehoueses are Vietnam, local time is 12 hours ahead #(lf)SET @tran_list#(lf)    = '111, 119, 120, 151, 172, 201, 251, 253, 255, 262, 301, 303, 305, 307, 311, 313, 321, 325, 331, 401, 420, 601, 800, 810, 114';#(lf)SET @tran_list_withoutPickPut = '119, 120, 172, 251, 255, 301, 307, 331, 401, 420, 601, 800, 810, 114';#(lf)#(lf)#(lf)#(lf)SELECT T1.wh_id#(lf)     , employee_id#(lf)     , employee_name#(lf)     --, supervisor_name#(lf)     , department_name#(lf)     , trantype_unit#(lf)     , tran_type#(lf)     , description#(lf)     , trantype_description#(lf)     --, concat(tran_type, '-', description)                            as trantype_description#(lf)     , l.[work_day]#(lf)     , l.actual_clock_in#(lf)     , l.actual_clock_out#(lf)     , l.WORKED_DAYS#(lf)     , DATEDIFF(SECOND, l.actual_clock_in, l.actual_clock_out) - 3600 AS spent_time_seconds#(lf)     , COUNT(DISTINCT [hu_id])                                        AS hu_id#(lf)     , COUNT([tran_qty])                                              AS count_of_tran#(lf)     , SUM([tran_qty])                                                AS sum_of_tran#(lf)     , CEILING(ABS(SUM(fractional_scoop)))                            AS fractional_hu_id#(lf)FROM#(lf)(#(lf)    SELECT T.*#(lf)         , T.tran_qty / NULLIF(i1.SCOOPQTY, 0) AS fractional_scoop#(lf)         , i1.SCOOPQTY#(lf)         , e.[WarehouseID]#(lf)         , e.[EMPLOYEENAME]              AS employee_name#(lf)         , e.[currentlyassigneddepartment]          AS department_id#(lf)         --, e.[SupervisorName]                  AS supervisor_name#(lf)         , G.[description]                 AS department_name#(lf)         , CASE#(lf)               WHEN T.tran_type IN ( SELECT trim(value)FROM string_split(@tran_list_withoutPickPut, ',')#(lf)                                   ) THEN#(lf)                   T.[tran_type]#(lf)               ELSE#(lf)                   concat(T.tran_type, '-', CASE WHEN i.[pick_put_id] = 'UPH' THEN 'UPH' ELSE 'CG' END)#(lf)           END                                 AS trantype_unit#(lf)         , concat(#(lf)                     CASE#(lf)                         WHEN T.tran_type IN ( SELECT trim(value)FROM string_split(@tran_list_withoutPickPut, ',')#(lf)                                             ) THEN#(lf)                             T.[tran_type]#(lf)                         ELSE#(lf)                             concat(T.tran_type, '-', CASE WHEN i.[pick_put_id] = 'UPH' THEN 'UPH' ELSE 'CG' END)#(lf)                     END, '-', T.description#(lf)                 )                             AS trantype_description#(lf)    FROM#(lf)    (#(lf)        SELECT wh_id#(lf)             , employee_id#(lf)             , item_number#(lf)             , start_tran_date#(lf)             , start_tran_time#(lf)             , end_tran_date#(lf)             , end_tran_time#(lf)             , hu_id#(lf)             , tran_qty#(lf)             , tran_type#(lf)             , description#(lf)             , CONCAT(CAST([start_tran_date] AS DATE), ' ', CAST([start_tran_time] AS TIME)) AS start_tran_date_time#(lf)             , CONCAT(CAST([end_tran_date] AS DATE), ' ', CAST([end_tran_time] AS TIME))     AS end_tran_date_time#(lf)        FROM [Distribution_Warehouse_Wholesale].[TranLog]#(lf)        WHERE CAST([start_tran_date] AS DATE)#(lf)              --between '20211128' and '20211205'#(lf)              BETWEEN DATEADD(   WEEK, -2, #(lf)                                               #(lf)                                                   CAST(DATEADD(HOUR, 7, GETUTCDATE()) AS DATE)#(lf)                                           #(lf)                             ) AND DATEADD(   DAY, 1, #(lf)                                                              CAST(DATEADD(HOUR, 7, GETUTCDATE()) AS DATE)#(lf)                                                      #(lf)                                          )#(lf)              AND [wh_id] IN#(lf)                  (#(lf)                      SELECT trim(value)FROM string_split(@wh_id_list, ',')#(lf)                  )#(lf)              AND tran_type IN ( SELECT trim(value)FROM string_split(@tran_list, ',')#(lf)                               )#(lf)              AND#(lf)              (#(lf)                  description NOT LIKE 'RETRO%'#(lf)                  OR description NOT LIKE 'Retro%'#(lf)              )#(lf)    )                                                                T#(lf)        LEFT JOIN [PowerBI_Distribution].[DimEmployee]               E#(lf)            ON T.[employee_id] = e.[employeenumber]#(lf)               AND T.[wh_id] = e.[WarehouseID]#(lf)        LEFT JOIN [Distribution_Warehouse_Wholesale].[Department]          G#(lf)            ON E.[currentlyassigneddepartment] = g.[department]#(lf)               AND e.[warehouseid] = g.[wh_id]#(lf)        LEFT JOIN [Distribution_Warehouse_Wholesale].[t_item_master] i#(lf)            ON CAST(T.[wh_id] AS varchar(10)) = CAST(i.[wh_id] AS varchar(10))#(lf)               AND CAST(T.[item_number] AS VARCHAR(10)) = CAST(i.[item_number] AS VARCHAR(10))#(lf)        LEFT JOIN MasterData_ItemMaster_AFI.ITBEXT                   i1#(lf)            ON T.[wh_id] = i1.HOUSE#(lf)               AND T.item_number = i1.ITNBR#(lf)#(lf))     t1#(lf)    LEFT JOIN#(lf)    (#(lf)        SELECT DISTINCT#(lf)               t.[work_day]#(lf)             , t.WhseEmpNumber#(lf)             , t.EmployeeNumber#(lf)             , t.EmployeeName#(lf)             , t.[home_department]#(lf)             , t.home_wh_id#(lf)             , MIN(t.actual_clock_in)  actual_clock_in#(lf)             , MAX(t.actual_clock_out) actual_clock_out#(lf)             , MAX(t.[End Time])       [End Time]#(lf)             , t.WORKED_DAYS#(lf)        FROM#(lf)        (#(lf)            SELECT [cico_key]#(lf)                 , [wh_id]#(lf)                 , b.WarehouseID#(lf)                 , a.home_wh_id#(lf)                 , [work_day]#(lf)                 , [work_shift_id]#(lf)                 , [employee_id]#(lf)                 , b.WhseEmpNumber#(lf)                 , b.EmployeeNumber#(lf)                 , b.EmployeeName#(lf)                 , [clock_in]#(lf)                 , [clock_out]#(lf)                 , [actual_clock_in]#(lf)                 , [actual_clock_out]#(lf)                 , CASE#(lf)                       WHEN a.actual_clock_out <> '' THEN#(lf)                           a.actual_clock_out#(lf)                       ELSE#(lf)                           DATEADD(HOUR, 7, GETUTCDATE())#(lf)                   END                                    AS [End Time]#(lf)                 , [supervisor_nbr]#(lf)                 , [home_supervisor_nbr]#(lf)                 , [group_nbr]#(lf)                 , [home_group_nbr]#(lf)                 , [department]#(lf)                 , [home_department]#(lf)                 , DATEDIFF(DAY, b.[HireDate], GETDATE()) AS WORKED_DAYS#(lf)            FROM [Distribution_Warehouse_Wholesale].[EmployeeClockInOut] a#(lf)                LEFT JOIN [PowerBI_Distribution].[DimEmployee]                        b#(lf)                    ON a.employee_id = b.EmployeeID#(lf)                       AND a.home_wh_id = b.WarehouseID#(lf)            WHERE CAST([work_day] AS DATE)#(lf)                  --between '20211128' and '20211204'#(lf)                  BETWEEN DATEADD(   WEEK, -2, #(lf)                                                       CAST(DATEADD(HOUR, 7, GETUTCDATE()) AS DATE)#(lf)                                               #(lf)                                 ) AND #(lf)                                               CAST(DATEADD(HOUR, 7, GETUTCDATE()) AS DATE)#(lf)                                       #(lf)#(lf)                  AND [home_wh_id] IN#(lf)                      (#(lf)                          SELECT trim(value)FROM string_split(@wh_id_list, ',')#(lf)                      )#(lf)        ) t#(lf)        --where t.WORKED_DAYS > 42#(lf)        --and t.EmployeeNumber = '153092'#(lf)        GROUP BY t.work_day#(lf)               , t.WhseEmpNumber#(lf)               , t.EmployeeNumber#(lf)               , t.EmployeeName#(lf)               , t.home_department#(lf)               , t.home_wh_id#(lf)               , t.WORKED_DAYS#(lf)    --order by t.work_day desc#(lf)#(lf)    ) l#(lf)        ON T1.[employee_id] = l.EmployeeNumber#(lf)           AND T1.[wh_id] = l.home_wh_id#(lf)WHERE#(lf)    /*#(lf)T.employee_id IN ( '123362' )#(lf)AND T.[start_tran_date]#(lf)BETWEEN '20210926' AND '20210927'#(lf)*/#(lf)    --AND#(lf)    T1.end_tran_date_time >= l.actual_clock_in#(lf)    AND T1.end_tran_date_time <= CASE WHEN l.actual_clock_out <> '' THEN l.actual_clock_out ELSE [End Time] END#(lf)    AND T1.start_tran_date_time >= l.actual_clock_in#(lf)    AND T1.start_tran_date_time <= CASE WHEN l.actual_clock_out <> '' THEN l.actual_clock_out ELSE [End Time] END#(lf)    AND l.actual_clock_in IS NOT NULL#(lf)    AND l.actual_clock_out IS NOT NULL#(lf)#(tab)AND DATEDIFF(Hour, l.actual_clock_in, l.actual_clock_out) < 24 --difference in clockout and clock in should not be more than 24 hrs, adding this condition to remove bad data#(lf)#(tab)AND DATEDIFF(Hour, l.actual_clock_in, l.actual_clock_out) >= 0 --clockout should be after clock in, adding this condition to remove bad data#(lf)GROUP BY T1.wh_id#(lf)       , employee_id#(lf)       , employee_name#(lf)       --, supervisor_name#(lf)       , department_name#(lf)       , trantype_unit#(lf)       , tran_type#(lf)       , DESCRIPTION#(lf)       , trantype_description#(lf)       , l.[work_day]#(lf)       , l.actual_clock_in#(lf)       , l.actual_clock_out#(lf)       , l.WORKED_DAYS;#(lf)#(lf)--) t2;", CreateNavigationProperties=false, CommandTimeout=#duration(0, 2, 40, 0)])
		in
		    Source
	lineageTag: 618768e0-0917-4e9e-bbae-66abf6491158

