expression 'SAM Overages' =
		let
		    Source = Sql.Database("ashley-edw.database.windows.net", "ASHLEY_EDW", [Query="SELECT       #(lf) a.wh_id   #(lf),a.employee_id#(lf),a.EmployeeNumber   #(lf),a.process_id  #(lf), labor_type  -- 2011-04-07 Erik Easton - Added#(lf), process_name#(lf)--, additional_description  #(lf), work_day  #(lf), process_transaction  #(lf), MIN(process_start) AS first_process_start  #(lf), MAX(process_end) AS last_process_end  #(lf), SUM([actual_elapsed_time]) AS actual_time   #(lf), SUM([total_sam]) AS sam   #(lf)#(lf)FROM(#(lf)SELECT [process_report_id]#(lf)      ,a.[process_id]#(lf)#(tab)  ,b.process_name#(lf)      ,[equipment_type_id]#(lf)      ,[equipment_id]#(lf)      ,a.[wh_id]#(lf)      ,[employee_id]#(lf)#(tab)  ,c.EmployeeNumber#(lf)      ,[work_shift_id]#(lf)      ,[work_day]#(lf)      ,[process_start]#(lf)      ,[process_end]#(lf)      ,[start_location]#(lf)      ,[previous_location]#(lf)      ,[actual_elapsed_time]#(lf)      ,[process_transaction]#(lf)      ,[goal_time_transaction]#(lf)      ,a.[type]#(lf)      ,[total_sam]#(lf)      ,a.[labor_type]#(lf)      ,[status]#(lf)      ,[cico_key]#(lf)      ,[home_wh_id]#(lf)      ,[supervisor_nbr]#(lf)      ,[home_supervisor_nbr]#(lf)      ,[group_nbr]#(lf)      ,[home_group_nbr]#(lf)      ,[department]#(lf)      ,[home_department]#(lf)      ,[company_nbr]#(lf)      ,[facility_nbr]#(lf)      ,[date_created]#(lf)      ,[date_modified]#(lf)      ,[modified_by]#(lf)      ,[source]#(lf)      ,[la_unit]#(lf)      ,[superintendent_nbr]#(lf)      ,[total_grabs]#(lf)      ,[total_cubes]#(lf)      ,[total_travel]#(lf)  FROM [Distribution_Warehouse_Wholesale].[ProcessReport] a#(lf)  INNER JOIN  [Distribution_Warehouse_Wholesale].[t_la_process] b ON a.process_id=b.process_id AND a.wh_id=b.wh_id#(lf)  INNER JOIN [PowerBI_Distribution].[DimEmployee] c ON a.wh_id=c.WarehouseID AND a.employee_id=c.EmployeeID#(lf)  WHERE a.wh_id IN ('335','35')#(lf)  AND a.[work_day] >DATEADD(DAY,-15,GETDATE())#(lf)  AND a.[type] IN ('I','TM')#(lf)  and a.[process_id] in ('28','19','44','46')#(lf)  --and c.employeenumber='119974'#(lf)#(lf)  ) a#(lf)#(lf) GROUP BY#(lf) a.wh_id   #(lf),a.employee_id#(lf),a.EmployeeNumber      #(lf),a.process_id  #(lf), labor_type  -- 2011-04-07 Erik Easton - Added#(lf), process_name #(lf)--, additional_description  #(lf), work_day  #(lf), process_transaction", CreateNavigationProperties=false, CommandTimeout=#duration(0, 2, 40, 0)]),
		    #"Added Custom" = Table.AddColumn(Source, "WhseEmployee#", each [wh_id]&"-"&[EmployeeNumber]),
		    #"Filtered Rows" = Table.SelectRows(#"Added Custom", each true),
		    #"Added Custom1" = Table.AddColumn(#"Filtered Rows", "over sam test", each if[actual_time]>[sam] then "Yes" else "No"),
		    #"Filtered Rows1" = Table.SelectRows(#"Added Custom1", each ([over sam test] = "Yes")),
		    #"Added Custom2" = Table.AddColumn(#"Filtered Rows1", "Time Over SAM", each [actual_time]-[sam]),
		    #"Added Conditional Column2" = Table.AddColumn(#"Added Custom2", "Function", each if [process_id] = 44 then "BREAK" else if [process_id] = 46 then "LUNCH" else if [process_id] = 28 then "PICKING" else if [process_id] = 19 then "LOADING" else "NONE"),
		    #"Added Custom4" = Table.AddColumn(#"Added Conditional Column2", "DC & Function", each [wh_id]&"-"&[Function]),
		    #"Added Custom3" = Table.AddColumn(#"Added Custom4", "qty", each 1),
		    #"Duplicated Column" = Table.DuplicateColumn(#"Added Custom3", "work_day", "work_day - Copy"),
		    #"Calculated End of Week" = Table.TransformColumns(#"Duplicated Column",{{"work_day - Copy", Date.EndOfWeek, type datetime}}),
		    #"Changed Type" = Table.TransformColumnTypes(#"Calculated End of Week",{{"work_day - Copy", type date}}),
		    #"Renamed Columns" = Table.RenameColumns(#"Changed Type",{{"work_day - Copy", "Week Ending Date"}})
		in
		    #"Renamed Columns"
	lineageTag: cd44c68a-d471-4539-b923-7de47e73e8cd

