	measure '5_DC All in PPH Unload + Load LCL (LastWeek)' =
			
			VAR _CL    = [5_DC All in PPH Unload + Load CL (LastWeek)]
			VAR _Sigma = [5_DC All in PPH Unload + Load Sigma (LastWeek)]
			RETURN
			IF (
			    NOT ISBLANK ( _CL ) && NOT ISBLANK ( _Sigma ),
