	measure '1_WN3 All in PPH Shipping Hours' =
			
			CALCULATE(
			    SUM(Fct_Supervisors_Hours[Final_Hrs_All_In]),
			     Fct_Supervisors_Hours[Position] IN {"WN3 - Shipping"}
			)
		displayFolder: 1_WN3 All in PPH Shipping
		lineageTag: 4169ede3-7f56-4b37-9f90-6ed3f4cf5087

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '1_WN3 All in PPH Shipping' =
			
			DIVIDE(
			    [1_WN3_All in PPH Shipping Pieces],
			    [1_WN3 All in PPH Shipping Hours]
			)
		displayFolder: 1_WN3 All in PPH Shipping
		lineageTag: 973095b9-aaf0-4f4b-a381-53c3f2d9f9e8

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '1_WN3 All in PPH Shipping (LastDate Label)' = ```
			
			VAR LastVisibleDate =
			    MAXX (
			        ALLSELECTED ( 'Dim_Calendar'[Date] ),   -- 当前报表/切片器下能看到的最大日期
			        'Dim_Calendar'[Date]
			    )
			VAR CurrDate =
			    MAX ( 'Dim_Calendar'[Date] )
			RETURN
			IF (
			    CurrDate = LastVisibleDate,
			    [1_WN3 All in PPH Shipping],               -- 只在最后一天返回数值
			    BLANK ()                                   -- 其他日期都为空
			)
			
			```
		displayFolder: 1_WN3 All in PPH Shipping
		lineageTag: 788bd764-d5a5-4425-942f-915b074a8def

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '1_WN3 All in PPH Shipping (Daily, NoDims)' = ```
			
			//-- ① 每日 PPH（去掉 Group / Shift / Employee 等维度，只按日期算）
			CALCULATE(
			    [1_WN3 All in PPH Shipping],      -- 你原来的度量：Pieces ÷ Hours
			    REMOVEFILTERS('Dim_Group'),
			    REMOVEFILTERS('Dim_Team'),
			    REMOVEFILTERS('Dim_Shift'),
			    REMOVEFILTERS('Dim_Employee'),
			    REMOVEFILTERS('Dim_PPH_Type')
			)
			
			```
		displayFolder: 1_WN3 All in PPH Shipping
		lineageTag: 62829540-01cf-4f1a-b15c-39556af1cae7

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '1_WN3 All in PPH Shipping CL (LastWeek)' =
			
			VAR _utc    = 7/24
			VAR _today  = INT ( TODAY() + _utc )
			VAR _currSun = _today - WEEKDAY(_today, 1) + 1
			VAR _start   = _currSun - 7
			VAR _end     = _start + 6
			
			VAR DateWindow =
			    FILTER (
			        ALL ( 'Dim_Calendar' ),
			        'Dim_Calendar'[Date] >= _start &&
			        'Dim_Calendar'[Date] <= _end
			    )
			RETURN
			CALCULATE (
			    AVERAGEX (
			        VALUES ( 'Dim_Calendar'[Date] ),
			        [1_WN3 All in PPH Shipping (Daily, NoDims)]
			    ),
			    DateWindow
			)
		displayFolder: 1_WN3 All in PPH Shipping
		lineageTag: 8495d0b5-f222-4de2-9678-625195ac8f55

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '1_WN3 All in PPH Shipping Sigma (LastWeek)' =
			
			VAR _utc    = 7/24
			VAR _today  = INT ( TODAY() + _utc )
			VAR _currSun = _today - WEEKDAY(_today, 1) + 1
			VAR _start   = _currSun - 7
			VAR _end     = _start + 6
			
			VAR DateWindow =
			    FILTER (
			        ALL ( 'Dim_Calendar' ),
			        'Dim_Calendar'[Date] >= _start &&
			        'Dim_Calendar'[Date] <= _end
			    )
			RETURN
			CALCULATE (
			    STDEVX.S (
			        VALUES ( 'Dim_Calendar'[Date] ),
			        [1_WN3 All in PPH Shipping (Daily, NoDims)]
			    ),
			    DateWindow
			)
		displayFolder: 1_WN3 All in PPH Shipping
		lineageTag: d4df3d84-27f8-4621-a2b8-1eb2a27384b0

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '1_WN3 All in PPH Shipping UCL (LastWeek)' =
			
			VAR _CL    = [1_WN3 All in PPH Shipping CL (LastWeek)]
			VAR _Sigma = [1_WN3 All in PPH Shipping Sigma (LastWeek)]
			RETURN
			IF (
			    NOT ISBLANK ( _CL ) && NOT ISBLANK ( _Sigma ),
			    _CL + 3 * _Sigma
			)
		displayFolder: 1_WN3 All in PPH Shipping
		lineageTag: 407864c2-ee2d-4bf8-a906-dd82429f2493

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '1_WN3 All in PPH Shipping LCL (LastWeek)' =
			
			VAR _CL    = [1_WN3 All in PPH Shipping CL (LastWeek)]
			VAR _Sigma = [1_WN3 All in PPH Shipping Sigma (LastWeek)]
			RETURN
			IF (
			    NOT ISBLANK ( _CL ) && NOT ISBLANK ( _Sigma ),
			    MAX ( 0, _CL - 3 * _Sigma )    -- 不要小于 0
			)
		displayFolder: 1_WN3 All in PPH Shipping
		lineageTag: 6065ae1d-074e-43bf-b421-5c8a940837b8

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '1_WN3 All in PPH Shipping Target Line' = 13
		formatString: 0
		displayFolder: 1_WN3 All in PPH Shipping
		lineageTag: 971b366c-6315-4648-9735-e2ec8f68ca5a

	measure 'LastWeek Sun-Sat Flag' = ```
			
			VAR _utc    = 7/24
			VAR _today  = INT ( TODAY() + _utc )          -- 今天（按越南时区）
			VAR _currSun = _today - WEEKDAY(_today, 1) + 1  -- 本周周日
			VAR _start   = _currSun - 7                   -- 上周周日
			VAR _end     = _start + 6                     -- 上周周六
			VAR d        = SELECTEDVALUE('Dim_Calendar'[Date])
			RETURN
			IF (
			    NOT ISBLANK(d) &&
			    d >= _start &&
			    d <= _end,
			    1,
			    0
			)
			
			```
		formatString: 0
		displayFolder: 0_Commn
		lineageTag: 650b97d6-192c-48d7-b12c-cc088ecd7ef5

