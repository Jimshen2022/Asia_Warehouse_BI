	measure 'Week Rank' = ```
			
			VAR v = [Week Avg Achievement%]
			VAR _isEmployeeRow =
			    ISINSCOPE ( Dim_Employee[Employee_ID] )
			RETURN
			IF (
			    NOT _isEmployeeRow,
			    BLANK(),                 -- 🔴 Total / 小计行不显示 Rank
			    IF (
			        ISBLANK ( v ),
			        BLANK(),
			        RANKX (
			            CALCULATETABLE (
			                ALL ( Dim_Employee[Employee_ID] ),
			                REMOVEFILTERS ( Dim_Employee[Employee_Name] ),
			                REMOVEFILTERS ( Dim_Shift ),
			                REMOVEFILTERS ( Dim_Position )
			            ),
			            CALCULATE (
			                [Week Avg Achievement%],
			                REMOVEFILTERS ( Dim_Employee[Employee_Name] ),
			                REMOVEFILTERS ( Dim_Shift ),
			                REMOVEFILTERS ( Dim_Position )
			            ),
			            ,
			            DESC,
			            DENSE
			        )
			    )
			)
			
			
