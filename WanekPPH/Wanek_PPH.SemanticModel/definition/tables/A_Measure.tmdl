	measure Html_Navigate_Pro = ```
			
			"<!DOCTYPE html>
			<html>
			<head>
			  <meta charset='UTF-8'>
			  <meta name='viewport' content='width=device-width, initial-scale=1.0'>
			  <title>Ashton PPH Dashboard</title>
			  <style>
			    /* 全局重置样式 - 移除默认边距和内边距 */
			    /* Global reset - Remove default margins/paddings */
			    * {
			      margin: 0;
			      padding: 0;
			      box-sizing: border-box;
			    }
			    
			    /* 主体样式 - 设置背景渐变和居中布局 */
			    /* Body styles - Set gradient background and centered layout */
			    body {
			      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
			      /*background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); !* 紫色渐变背景 / Purple gradient *!*/
			      background: #4a4f58; /* 紫色渐变背景 / Purple gradient */
			      min-height: 100vh;
			      display: flex;
			      justify-content: center;
			      align-items: center;
			      padding: 20px;
			    }
			    
			    /* 主容器样式 - 白色半透明卡片容器 */
			    /* Main container - White semi-transparent card container */
			    .container {
			      max-width: 1200px;
			      width: 100%;
			      background: rgba(255, 255, 255, 0.95);
			      border-radius: 20px;
			      padding: 40px;
			      box-shadow: 0 20px 60px rgba(0,0,0,0.3);
			    }
			    
			    /* 页头样式 - 标题区域居中 */
			    /* Header styles - Centered title area */
			    header {
			      text-align: center;
			      margin-bottom: 40px;
			    }
			    
			    /* 主标题样式 */
			    /* Main title styles */
			    h1 {
			      color: #333;
			      font-size: 2.5em;
			      margin-bottom: 10px;
			      font-weight: 700;
			    }
			    
			    /* 副标题样式 */
			    /* Subtitle styles */
			    .subtitle {
			      color: #666;
			      font-size: 1.2em;
			      font-weight: 300;
			    }
			    
			    /* 卡片网格布局 - 响应式网格系统 */
			    /* Card grid layout - Responsive grid system */
			    .card-grid {
			      display: grid;
			      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
			      gap: 25px;
			      margin-bottom: 30px;
			    }
			    
			    /* 单个卡片样式 - 带悬停效果的交互卡片 */
			    /* Individual card styles - Interactive card with hover effects */
			    .card {
			      background: white;
			      border-radius: 15px;
			      padding: 25px;
			      text-decoration: none;
			      color: inherit;
			      transition: all 0.3s ease;
			      border: 2px solid transparent;
			      cursor: pointer;
			      box-shadow: 0 5px 15px rgba(0,0,0,0.1);
			    }
			    
			    /* 卡片悬停效果 - 上浮和加强阴影 */
			    /* Card hover effect - Lift up and enhance shadow */
			    .card:hover {
			      transform: translateY(-5px);
			      box-shadow: 0 15px 30px rgba(0,0,0,0.2);
			      border-color: #667eea;
			    }
			    
			    /* 卡片图标样式 */
			    /* Card icon styles */
			    .card-icon {
			      font-size: 2.5em;
			      margin-bottom: 15px;
			      display: block;
			    }
			    
			    /* 卡片标题样式 */
			    /* Card title styles */
			    .card-title {
			      font-size: 1.3em;
			      font-weight: 600;
			      color: #333;
			      margin-bottom: 10px;
			    }
			    
			    /* 卡片描述文字样式 */
			    /* Card description text styles */
			    .card-desc {
			      color: #777;
			      font-size: 0.95em;
			      line-height: 1.5;
			    }
			    
			    /* 底部操作按钮区域 - Flexbox居中布局 */
			    /* Footer actions area - Flexbox centered layout */
			    .footer-actions {
			      display: flex;
			      gap: 15px;
			      justify-content: center;
			      flex-wrap: wrap;
			    }
			    
			    /* 通用按钮样式 */
			    /* Common button styles */
			    .btn {
			      padding: 15px 30px;
			      border-radius: 10px;
			      text-decoration: none;
			      font-weight: 600;
			      transition: all 0.3s ease;
			      cursor: pointer;
			      border: none;
			      font-size: 1em;
			    }
			    
			    /* 主按钮样式 - 紫色渐变 */
			    /* Primary button - Purple gradient */
			    .btn-primary {
			      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
			      color: white;
			    }
			    
			    /* 主按钮悬停效果 */
			    /* Primary button hover effect */
			    .btn-primary:hover {
			      transform: scale(1.05);
			      box-shadow: 0 10px 20px rgba(102, 126, 234, 0.4);
			    }
			    
			    /* 次要按钮样式 - 绿色 */
			    /* Secondary button - Green */
			    .btn-secondary {
			      background: #28a745;
			      color: white;
			    }
			    
			    /* 次要按钮悬停效果 */
			    /* Secondary button hover effect */
			    .btn-secondary:hover {
			      transform: scale(1.05);
			      background: #218838;
			    }
			    
			    /* 移动端响应式样式 - 小于768px屏幕 */
			    /* Mobile responsive styles - Screens smaller than 768px */
			    @media (max-width: 768px) {
			      h1 { font-size: 2em; }
			      .container { padding: 20px; }
			      .card-grid { grid-template-columns: 1fr; }
			    }
			  </style>
			</head>
			<body>
			<div class='container'>
			  <!-- 页头区域：标题和副标题 -->
			  <!-- Header area: Title and subtitle -->
			  <header>
			    <h1>Wanek PPH Dashboard</h1>
			    <div class='subtitle'>Performance & Productivity Navigation</div>
			  </header>
			  
			  <!-- 卡片网格区域：4个导航卡片 -->
			  <!-- Card grid area: 4 navigation cards -->
			  <div class='card-grid'>
			    <!-- 卡片1: 总体PPH趋势 -->
			    <!-- Card 1: Overall PPH Trend -->
			    <a href='#' class='card' onclick='navigateToBookmark(""All in PPH Trend"")'>
			      <span class='card-icon'>📊</span>
			      <div class='card-title'>All in PPH</div>
			      <div class='card-desc'>Overall pieces-per-hour across operations.</div>
			    </a>
			    
			    <!-- 卡片2: 个人PPH -->
			    <!-- Card 2: Individual PPH -->
			    <a href='#' class='card' onclick='navigateToBookmark(""Individual PPH"")'>
			      <span class='card-icon'>👤</span>
			      <div class='card-title'>Individual PPH</div>
			      <div class='card-desc'>Employee-level performance distribution.</div>
			    </a>
			    
			    <!-- 卡片3: 周排名 -->
			    <!-- Card 3: Weekly Ranking -->
			    <a href='#' class='card' onclick='navigateToBookmark(""Weekly PPH Rank"")'>
			      <span class='card-icon'>📅</span>
			      <div class='card-title'>Weekly PPH Rank</div>
			      <div class='card-desc'>Weekly ranking by team and employee.</div>
			    </a>
			    
			    <!-- 卡片4: 月排名 -->
			    <!-- Card 4: Monthly Ranking -->
			    <a href='#' class='card' onclick='navigateToBookmark(""Monthly PPH Rank"")'>
			      <span class='card-icon'>📈</span>
			      <div class='card-title'>Monthly PPH Rank</div>
			      <div class='card-desc'>Monthly trend and ranking summary.</div>
			    </a>
			  </div>
			  
			  <!-- 底部操作按钮区域 -->
			  <!-- Footer action buttons area -->
			  <div class='footer-actions'>
			    <!-- 维护PPH目标按钮 -->
			    <!-- Maintain PPH Goal button -->
			    <button class='btn btn-primary' onclick='navigateToBookmark(""Maintain PPH Goal"")'>Maintain PPH Goal</button>
			    
			    <!-- 下载PPH详情按钮 -->
			    <!-- Download PPH Details button -->
			    <button class='btn btn-secondary' onclick='navigateToBookmark(""Download PPH Details"")'>Download PPH Details</button>
			  </div>
			</div>
			
			<script>
			  /**
			   * Power BI 书签导航函数
			   * Power BI Bookmark Navigation Function
			   * 
			   * @param {string} bookmarkName - Power BI 书签名称 / Power BI bookmark name
			   * 
			   * 功能说明 / Function description:
			   * 1. 检查 Power BI 的 webpackJsonp 是否存在 / Check if Power BI's webpackJsonp exists
			   * 2. 查找书签管理器模块 / Find bookmark manager module
			   * 3. 执行书签导航 / Execute bookmark navigation
			   */
			  function navigateToBookmark(bookmarkName) {
			    try {
			      // 方法1: 使用 Power BI 的全局对象（如果可用）
			      // Method 1: Use Power BI global object (if available)
			      if (window.powerbi) {
			        window.powerbi.bookmarksManager.apply(bookmarkName);
			        return;
			      }
			      
			      // 方法2: 通过 webpackJsonp 查找书签管理器
			      // Method 2: Find bookmark manager through webpackJsonp
			      if (window.webpackJsonp) {
			        window.webpackJsonp([], {
			          0: function(n, o, t) {
			            // 查找书签管理器模块
			            // Find bookmark manager module
			            var bookmarkManager = t(""BookmarksManager"");
			            if (bookmarkManager && bookmarkManager.applyBookmark) {
			              bookmarkManager.applyBookmark(bookmarkName);
			            }
			          }
			        }, [0]);
			      }
			      
			      // 方法3: 发送自定义事件（备用方案）
			      // Method 3: Send custom event (fallback)
			      var event = new CustomEvent('navigateToBookmark', {
			        detail: { bookmarkName: bookmarkName }
			      });
			      window.dispatchEvent(event);
			      
			      // 在控制台输出导航信息（调试用）
			      // Output navigation info to console (for debugging)
			      console.log('Navigating to bookmark: ' + bookmarkName);
			      
			    } catch (error) {
			      // 错误处理 / Error handling
