	measure '5_DC All in PPH Unload + Load CL (LastWeek)' =
			
			VAR _utc    = 7/24
			VAR _today  = INT ( TODAY() + _utc )
			VAR _currSun = _today - WEEKDAY(_today, 1) + 1
			VAR _start   = _currSun - 7
			VAR _end     = _start + 6
			
			VAR DateWindow =
			    FILTER (
			        ALL ( 'Dim_Calendar' ),
			        'Dim_Calendar'[Date] >= _start &&
			        'Dim_Calendar'[Date] <= _end
			    )
			RETURN
			CALCULATE (
			    AVERAGEX (
			        VALUES ( 'Dim_Calendar'[Date] ),
			        [5_DC All in PPH Unload + Load (Daily, NoDims)]
			    ),
			    DateWindow
			)
		displayFolder: 5_DC All in PPH Unload + Load
		lineageTag: 53e4ccdd-c50f-4fee-b45d-5d5aec178509

		annotation PBI_FormatHint = {"isGeneralNumber":true}

