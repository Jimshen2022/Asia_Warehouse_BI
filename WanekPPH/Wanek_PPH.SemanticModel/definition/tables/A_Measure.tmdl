			      flex-shrink: 0;
			      padding-top: 5px;  /* 👈 减少顶部间距 */
			      padding-bottom: 5px;  /* 👈 减少底部间距 */
			      margin-bottom: 0;  /* 👈 移除底部边距 */
			    }
			    
			    .btn {
			      padding: 12px 24px;
			      border-radius: 8px;
			      text-decoration: none;
			      font-weight: 600;
			      transition: all 0.3s ease;
			      cursor: pointer;
			      border: none;
			      font-size: 0.95em;
			    }
			    
			    .btn-primary {
			      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
			      color: white;
			    }
			    
			    .btn-primary:hover {
			      transform: scale(1.05);
			      box-shadow: 0 8px 16px rgba(102, 126, 234, 0.3);
			    }
			    
			    .btn-secondary {
			      background: #28a745;
			      color: white;
			    }
			    
			    .btn-secondary:hover {
			      transform: scale(1.05);
			      background: #218838;
			    }
			    
			    /* 移动端响应式样式 */
			    @media (max-width: 768px) {
			      h1 { font-size: 1.8em; }
			      .container { padding: 10px 12px; }
			      .card-grid { 
			        grid-template-columns: 1fr;
			        gap: 12px;
			      }
			      .card { 
			        padding: 12px;
			        padding-top: 20px;
			        padding-bottom: 15px;
			      }
			      .btn { padding: 10px 20px; font-size: 0.9em; }
			    }
			  </style>
			</head>
			<body>
			<div class='container'>
			  <!-- 页头区域：标题和副标题 -->
			  <header>
			    <h1>Wanek PPH Dashboard</h1>
			    <div class='subtitle'>Performance & Productivity Navigation</div>
			  </header>
			  
			  <!-- 卡片网格区域：4个导航卡片 -->
			  <div class='card-grid'>
			    <!-- 卡片1: 总体PPH趋势 -->
			    <a href='#' class='card' onclick='navigateToBookmark(""All in PPH Trend"")'>
			      <span class='card-icon'>📊</span>
			      <div class='card-title'>All in PPH</div>
			      <div class='card-desc'>Overall pieces-per-hour across operations.</div>
			    </a>
			    
			    <!-- 卡片2: 个人PPH -->
			    <a href='#' class='card' onclick='navigateToBookmark(""Individual PPH Trend"")'>
			      <span class='card-icon'>👤</span>
			      <div class='card-title'>Individual PPH</div>
			      <div class='card-desc'>Employee-level performance distribution.</div>
			    </a>
			    
			    <!-- 卡片3: 周排名 -->
			    <a href='#' class='card' onclick='navigateToBookmark(""Weekly PPH Rank"")'>
			      <span class='card-icon'>📅</span>
			      <div class='card-title'>Weekly PPH Rank</div>
			      <div class='card-desc'>Weekly ranking by team and employee.</div>
			    </a>
			    
			    <!-- 卡片4: 月排名 -->
			    <a href='#' class='card' onclick='navigateToBookmark(""Monthly PPH Rank"")'>
			      <span class='card-icon'>📈</span>
			      <div class='card-title'>Monthly PPH Rank</div>
			      <div class='card-desc'>Monthly trend and ranking summary.</div>
			    </a>
			  </div>
			  
			  <!-- 底部操作按钮区域 -->
			  <div class='footer-actions'>
			    <!-- 维护PPH目标按钮 -->
			    <button class='btn btn-primary' onclick='navigateToBookmark(""Maintain PPH Goal"")'>Maintain PPH Goal</button>
			    
			    <!-- 下载PPH详情按钮 -->
			    <button class='btn btn-secondary' onclick='navigateToBookmark(""Download PPH Details"")'>Download PPH Details</button>
			  </div>
			</div>
			
			<script>
			  /**
			   * Power BI 书签导航函数
			   */
			  function navigateToBookmark(bookmarkName) {
			    try {
			      if (window.powerbi) {
			        window.powerbi.bookmarksManager.apply(bookmarkName);
			        return;
			      }
			      
			      if (window.webpackJsonp) {
			        window.webpackJsonp([], {
			          0: function(n, o, t) {
			            var bookmarkManager = t('BookmarksManager');
			            if (bookmarkManager && bookmarkManager.applyBookmark) {
			              bookmarkManager.applyBookmark(bookmarkName);
			            }
			          }
			        }, [0]);
			      }
			      
			      var event = new CustomEvent('navigateToBookmark', {
			        detail: { bookmarkName: bookmarkName }
			      });
			      window.dispatchEvent(event);
			      
			      console.log('Navigating to bookmark: ' + bookmarkName);
			      
			    } catch (error) {
			      console.error('Error navigating to bookmark:', error);
			    }
			  }
			  
			  document.addEventListener('DOMContentLoaded', function() {
			    var links = document.querySelectorAll('.card, .btn');
			    links.forEach(function(link) {
			      link.addEventListener('click', function(e) {
			        e.preventDefault();
			      });
			    });
			  });
			</script>
			</body>
			</html>"
			
