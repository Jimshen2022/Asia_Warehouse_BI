table A_Measure
	lineageTag: d0044d11-9b58-4635-96b6-bd4ff116557e

	measure '1_WN3_All in PPH Shipping Pieces' =
			
			CALCULATE(
			    'A_Measure'[0_Trx_Pieces],
			    Fct_Supervisors_Hours[Position] IN {"WN3 - Shipping"}
			)
		formatString: #,0
		displayFolder: 1_WN3 All in PPH Shipping
		lineageTag: 9b040ba9-4f37-48fc-b7db-e4f688c9b1c0

	measure 0_Trx_Pieces = SUM('Fct_Supervisors_Hours'[Transaction_Pieces])
		displayFolder: 0_Commn
		lineageTag: ad9f944a-557b-4ec9-9f22-6ef3d6eafe12

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '0_Individual PPH Pieces' = ```
			
