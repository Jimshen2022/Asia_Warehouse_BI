table Fct_All_Details_Rows_Summary
	lineageTag: ce14b7d2-1597-4784-abcd-a0c4bccbeded

	column Date
		formatString: General Date
		lineageTag: db35d48f-566c-4969-ae85-a674ee4521cb
		summarizeBy: none
