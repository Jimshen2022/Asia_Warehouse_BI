		lineageTag: 27d39478-c509-4444-8656-fd9416e00939
		summarizeBy: none
		isNameInferred
		sourceColumn: Dim_Metric[MetricName]

		annotation SummarizationSetBy = Automatic

	column 'PPH Metric Value'
		formatString: 0.0
		lineageTag: a0f1b362-afef-438c-97e4-a171d9c59b7c
		summarizeBy: sum
