		sourceColumn: Dim_Position[Position]

		annotation SummarizationSetBy = Automatic

	partition Fct_All_Details_Rows_Summary = calculated
		mode: import
		source = ```
				
				VAR _T =
				    SUMMARIZECOLUMNS(
				        'Dim_Calendar'[Date],
				        'Dim_Employee'[Employee_ID],
				        'Dim_Shift'[Shift],
				        'Dim_Site'[Site],
				        'Dim_Position'[Position],
				        'Dim_Metric'[MetricName],
				
				        "PPH Metric Value", [PPH Metric Value],
				        "Goal",            [Goal],
				        "Achievement%",    [Achievement%]
				    )
				RETURN
				    FILTER(
				        _T,
				        NOT ISBLANK ( [PPH Metric Value] )
				            && NOT CONTAINSSTRING ( 'Dim_Metric'[MetricName], "All in" )
				    )
				
				
				```

	annotation PBI_Id = c18a56e0c22e4f9591f3c6345f7e3c9c

