	partition Fct_Supervisors_Hours = m
		mode: import
		source = ```
				let
				    // 连接到 SharePoint 文件
				    Source = SharePoint.Files("https://masterashley.sharepoint.com/sites/AsiaWarehouseOperations/", [ApiVersion = 15]),
				    
				    // 筛选指定文件夹
				    #"Filtered Folder" = Table.SelectRows(Source, each Text.StartsWith([Folder Path], "https://masterashley.sharepoint.com/sites/AsiaWarehouseOperations/Shared Documents/Ashton/Four Box/Wanek_PPH/")),
				    
				    // 仅筛选 .xlsx 文件
				    #"Excel Files Only" = Table.SelectRows(#"Filtered Folder", each Text.EndsWith([Name], ".xlsx")),
				    
				    // 展开二进制内容
				    #"Added Custom" = Table.AddColumn(#"Excel Files Only", "Excel Tables", each Excel.Workbook([Content])),
				    
				    // 展开 Excel 表格
				    #"Expanded Excel Tables" = Table.ExpandTableColumn(#"Added Custom", "Excel Tables", {"Data", "Item", "Kind"}, {"Data", "Item", "Kind"}),
				    
				    // 仅保留名为 "DATA" 的工作表
				    #"Filtered Sheets" = Table.SelectRows(#"Expanded Excel Tables", each [Item] = "DATA"),
				    
				    // --- 核心修正点：动态获取所有文件的列名并展开，防止空表报错 ---
				    DynamicColumnNames = List.Distinct(List.Combine(List.Transform(#"Filtered Sheets"[Data], each if _ is table then Table.ColumnNames(_) else {}))),
				    #"Expanded Data" = Table.ExpandTableColumn(#"Filtered Sheets", "Data", DynamicColumnNames),
				    
				    // 添加源文件信息
				    #"Added Source Info" = Table.AddColumn(#"Expanded Data", "Source File", each [Name], type text),
				    #"Added Folder Info" = Table.AddColumn(#"Added Source Info", "Source Folder", each [Folder Path], type text),
				    #"Removed Other Columns" = Table.SelectColumns(#"Added Folder Info",{"Column1", "Column2", "Column3", "Column4", "Column5", "Column6", "Column7", "Column8", "Column9", "Column10", "Source File", "Source Folder"}),
				
				    // 添加索引
				    #"Added Index" = Table.AddIndexColumn(#"Removed Other Columns", "Row Index", 1, 1),
				
				    // 处理占位符
				    #"Modified First 1 Rows Source File" = Table.AddColumn(#"Added Index", "Source_File", each if [Row Index] <= 1 then "Source_File" else Text.From([Source File]), type text),
				    #"Modified First 1 Rows Source Folder" = Table.AddColumn(#"Modified First 1 Rows Source File", "Source_Folder", each if [Row Index] <= 1 then "Source_Folder" else Text.From([Source Folder]), type text),
				    #"Removed Columns" = Table.RemoveColumns(#"Modified First 1 Rows Source Folder",{"Source File", "Source Folder", "Row Index"}),
				    
				    // 提升标题
				    #"Promoted Headers" = Table.PromoteHeaders(#"Removed Columns", [PromoteAllScalars=true]),
				    
				    // 基础类型转换（全设为 any，方便后续替换字符）
				    #"Changed Type Initial" = Table.TransformColumnTypes(#"Promoted Headers",{{"Group", type text}, {"Date", type any}, {"Employee_ID", type any}, {"Final_Hrs_All_In", type any}, {"Final_Hrs_Individual", type any}}),
				    
				// 过滤掉空行和多余标题
				    #"Filtered Rows" = Table.SelectRows(#"Changed Type Initial", each ([Date] <> null and [Date] <> "Date")),
				
				    // --- 重点修正：改用 Table.TransformColumns，这种方法不会因为类型混合而报错 ---
				    #"Fixed Hyphens" = Table.TransformColumns(#"Filtered Rows", {
				        {"Final_Hrs_Individual", each if Text.Trim(Text.From(_)) = "-" then 0 else _, type any},
				        {"Final_Hrs_All_In", each if Text.Trim(Text.From(_)) = "-" then 0 else _, type any}
				    }),
				    
				    // 现在可以安全地转换类型了
				    #"Changed Final Types2" = Table.TransformColumnTypes(#"Fixed Hyphens",{
				        {"Date", type date},
				        {"Final_Hrs_Individual", type number},
				        {"Final_Hrs_All_In", type number},
				        {"Employee_ID", type text}
				    }),
				    
				    // 将Date和数字列进行真正的类型转换
				    #"Changed Final Types" = Table.TransformColumnTypes(#"Fixed Hyphens",{
				        {"Date", type date},
				        {"Final_Hrs_Individual", type number},
				        {"Final_Hrs_All_In", type number},
				        {"Employee_ID", type text}
				    }),
				    
				    // 筛选最近1000天
				    #"Filtered Last Days" = Table.SelectRows(#"Changed Final Types", 
				        each [Date] >= Date.AddDays(Date.From(DateTime.LocalNow()), -1000) and 
				             [Date] <= Date.From(DateTime.LocalNow())),
				    
				    // 格式化 Employee_ID
				    #"Formatted Employee_ID" = Table.TransformColumns(#"Filtered Last Days", {
				        {"Employee_ID", each if _ = null then null else Text.PadStart(Text.From(_), 5, "0")}
				    }),
				    
				    // 调用自定义函数
				    #"Added Custom2" = Table.AddColumn(#"Formatted Employee_ID", "HJ_Transaction_Pieces", each GetTotalPieces([Date],[Employee_ID],[PPH_Type])),
				    #"Removed Columns2" = Table.RemoveColumns(#"Added Custom2",{"HJ_Transaction_Pieces"}),
				        
				    // 提取 Site
				    #"Added Site" = Table.AddColumn(#"Removed Columns2", "Site", each 
				        if [Group] = null then null 
				        else Text.Trim(Text.Start(Text.From([Group]), 3)), 
				        type text)
				in
				    #"Added Site"
				```

