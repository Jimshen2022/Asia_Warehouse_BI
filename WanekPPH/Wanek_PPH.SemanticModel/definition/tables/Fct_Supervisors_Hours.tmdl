		annotation SummarizationSetBy = Automatic

	column Group_Date_Team_Avg_Runner_Transaction_Pieces = ```
			
			VAR _currDate =
			    Fct_Supervisors_Hours[Date]   -- 如果你表里是别的日期列名，改成对应的
			
			VAR _isRunnerRow =
			    Fct_Supervisors_Hours[Position] = "WN3 - Line Clearing"
			        && Fct_Supervisors_Hours[Team] = "T1"          -- 只给 T1（Runner）分配
			
			-- ① 这一天，B1 Ramp（T2）的总 transaction pieces
			VAR _totalPieces_T2_ByDate =
			    CALCULATE (
			        'A_Measure'[0_Trx_Pieces],          -- 你现成的 pieces 度量
			        ALLEXCEPT (
			            Fct_Supervisors_Hours,
			            Fct_Supervisors_Hours[Date],              -- 只按“日期”分组
			             Fct_Supervisors_Hours[Shift] 
			            -- 如果要按 日期+Shift，可以加上 Fct_Supervisors_Hours[Shift]
			            -- 如果要按 日期+Group，再加 Fct_Supervisors_Hours[Group]
			        ),
			        Fct_Supervisors_Hours[Position] = "WN3 - Line Clearing",
			        Fct_Supervisors_Hours[Team] = "T2"            -- Violet：T2 = B1 Ramp（取 qty）
			    )
			
			-- ② 这一天有多少个 Runner 员工（T1）
			VAR _runnerCount_T1_ByDate =
			    CALCULATE (
			        DISTINCTCOUNT ( Fct_Supervisors_Hours[Employee_ID] ),
			        ALLEXCEPT (
			            Fct_Supervisors_Hours,
			            Fct_Supervisors_Hours[Date],
			            Fct_Supervisors_Hours[Shift] 
			        ),
			        Fct_Supervisors_Hours[Position] = "WN3 - Line Clearing",
			        Fct_Supervisors_Hours[Team] = "T1"
			
			    )
			
			RETURN
			IF (
			    _isRunnerRow,
			    DIVIDE ( _totalPieces_T2_ByDate, _runnerCount_T1_ByDate ),   -- 平均到每个 Runner 身上
			    BLANK()
			)
			
			```
		lineageTag: 1cfb6650-3cad-46a5-bb38-6b615eaf2119
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column Group_Date_Team_Avg_Runner_Transaction_Hours = ```
			
			VAR _currDate =
			    Fct_Supervisors_Hours[Date]   -- 如果你表里是别的日期列名，改成对应的
			
			VAR _isRunnerRow =
			    Fct_Supervisors_Hours[Position] = "WN3 - Line Clearing"
			        && Fct_Supervisors_Hours[Team] = "T1"          -- 只给 T1（Runner）分配
			
			-- ① 这一天，B1 Ramp（T2）的总 transaction Hours
			VAR _totalPieces_T2_ByDate =
			    CALCULATE (
			        'A_Measure'[0_Hours_individual],          -- 你现成的Hour度量
			        ALLEXCEPT (
			            Fct_Supervisors_Hours,
			            Fct_Supervisors_Hours[Date],              -- 只按“日期”分组
			             Fct_Supervisors_Hours[Shift] 
			            -- 如果要按 日期+Shift，可以加上 Fct_Supervisors_Hours[Shift]
			            -- 如果要按 日期+Group，再加 Fct_Supervisors_Hours[Group]
			        ),
			        Fct_Supervisors_Hours[Position] = "WN3 - Line Clearing",
			        Fct_Supervisors_Hours[Team] = "T1"            -- Violet：T2 = B1 Ramp（取 qty）
			    )
			
			-- ② 这一天有多少个 Runner 员工（T1）
			VAR _runnerCount_T1_ByDate =
			    CALCULATE (
			        DISTINCTCOUNT ( Fct_Supervisors_Hours[Employee_ID] ),
			        ALLEXCEPT (
			            Fct_Supervisors_Hours,
			            Fct_Supervisors_Hours[Date],
			            Fct_Supervisors_Hours[Shift] 
			        ),
			        Fct_Supervisors_Hours[Position] = "WN3 - Line Clearing",
			        Fct_Supervisors_Hours[Team] = "T1"
			
			    )
			
			RETURN
			IF (
			    _isRunnerRow,
			    DIVIDE ( _totalPieces_T2_ByDate, _runnerCount_T1_ByDate ),   -- 平均到每个 Runner 身上
			    BLANK()
			)
			
			```
		formatString: #,0.00
