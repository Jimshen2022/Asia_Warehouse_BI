		annotation SummarizationSetBy = Automatic

	column Transaction_Pieces = ```
			
			VAR currentDate = 'Fct_Supervisors_Hours'[Date]
			VAR currentEmp = 'Fct_Supervisors_Hours'[Employee_ID]
			VAR baseFilter =
			    FILTER(
			        ALL('Fact_Transactions'),
			        'Fact_Transactions'[shift_date] = currentDate &&
			        'Fact_Transactions'[employee_id] = currentEmp
			    )
			RETURN
			SWITCH(TRUE(),
			        'Fct_Supervisors_Hours'[Position] = "DC Load",
			        CALCULATE(SUM('Fact_Transactions'[tran_qty]), 
			                  FILTER(baseFilter, 'Fact_Transactions'[pph_type] IN {"Picking", "Loading_PPH","Temp_Cont_Loading"} && 'Fact_Transactions'[site] IN {"DC"})),
			
			    'Fct_Supervisors_Hours'[Position] = "DC Put away",
			        CALCULATE(SUM('Fact_Transactions'[tran_qty]), 
			                  FILTER(baseFilter, 'Fact_Transactions'[pph_type] IN {"DC_Putaway", "Picking_PPH"} && 'Fact_Transactions'[site] IN {"DC"})),
			
			    'Fct_Supervisors_Hours'[Position] = "DC Unload + Load",
			        CALCULATE(SUM('Fact_Transactions'[tran_qty]), 
			                  FILTER(baseFilter, 'Fact_Transactions'[pph_type] IN {"Picking", "Loading_PPH", "DC_Unloading_PPH","Temp_Cont_Loading"} && 'Fact_Transactions'[site] IN {"DC"})),
			
			    'Fct_Supervisors_Hours'[Position] = "WN2 - Line Clearing",
			        CALCULATE(SUM('Fact_Transactions'[tran_qty]), 
			                  FILTER(baseFilter, 'Fact_Transactions'[pph_type] IN {"Production_Received"}  && 'Fact_Transactions'[site] IN {"WN2"} )),
			
			    'Fct_Supervisors_Hours'[Position] = "WN2 - Shipping",
			        CALCULATE(SUM('Fact_Transactions'[tran_qty]), 
			                  FILTER(baseFilter, 'Fact_Transactions'[pph_type] IN {"Picking","Picking_PPH", "Loading_PPH", "Temp_Cont_Loading"}  && 'Fact_Transactions'[site] IN {"WN2"} )),
			
			    'Fct_Supervisors_Hours'[Position] = "WN3 - Line Clearing",
			        CALCULATE(SUM('Fact_Transactions'[tran_qty]), 
			                  FILTER(baseFilter, 'Fact_Transactions'[pph_type] IN {"Production_Received"}  && 'Fact_Transactions'[site] IN {"WN3"} )),
			
			    'Fct_Supervisors_Hours'[Position] = "WN3 - Shipping",
			        CALCULATE(SUM('Fact_Transactions'[tran_qty]), 
			                  FILTER(baseFilter, 'Fact_Transactions'[pph_type] IN {"Picking","Picking_PPH", "Loading_PPH", "Temp_Cont_Loading"}  && 'Fact_Transactions'[site] IN {"WN3"} )),
			
			    BLANK()  -- 默认返回空值
			)
			
			```
		formatString: #,0
		lineageTag: 721fa5a9-8864-4867-a5b9-568f0fb4fa03
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column Group_Date_Team_Avg_Transaction_Pieces = ```
			
			VAR CurrentTeam = 'Fct_Supervisors_Hours'[Team]
			VAR CurrentPPHType = 'Fct_Supervisors_Hours'[PPH_Type]
			VAR AvgValue = 
			    IF(
			        NOT(ISBLANK(CurrentTeam)) && CurrentTeam <> "0" && NOT(ISBLANK(CurrentPPHType)),
			        CALCULATE(
			            DIVIDE(
			                SUM('Fct_Supervisors_Hours'[Transaction_Pieces]),
			                COUNTROWS('Fct_Supervisors_Hours')
			            ),
			            ALLEXCEPT('Fct_Supervisors_Hours', 'Fct_Supervisors_Hours'[Group],'Fct_Supervisors_Hours'[Date], 'Fct_Supervisors_Hours'[Team])
			        ),
			        'Fct_Supervisors_Hours'[Transaction_Pieces]
			    )
			RETURN
			    AvgValue
			
			```
		formatString: #,0
		lineageTag: 4453e471-fc63-4f9c-bc9b-359834ea5cb7
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column Group_Date_Team_Avg_Hrs = ```
			
			VAR CurrentTeam = 'Fct_Supervisors_Hours'[Team]
			VAR CurrentPPHType = Fct_Supervisors_Hours[PPH_Type]
			VAR AvgValue = 
			    IF(
			        NOT(ISBLANK(CurrentTeam)) && CurrentTeam <> "0" && NOT(ISBLANK(CurrentPPHType)),
			        CALCULATE(
			            DIVIDE(
			                SUM(Fct_Supervisors_Hours[Final_Hrs_Individual]),
			                COUNTROWS(Fct_Supervisors_Hours)
			            ),
			            ALLEXCEPT(Fct_Supervisors_Hours,'Fct_Supervisors_Hours'[Group], Fct_Supervisors_Hours[Date], Fct_Supervisors_Hours[Team])
			        ),
			        Fct_Supervisors_Hours[Final_Hrs_Individual]
			    )
			RETURN
			    AvgValue
			```
		formatString: #,0.0
		lineageTag: 2816c4d4-8d12-4b84-bce0-f48852061bcd
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

