		annotation SummarizationSetBy = Automatic

	column '1_All in PPH Shipping Pieces' = ```
			
			VAR d = Fct_Supervisors_Hours_Pieces[Date]
			VAR s = Fct_Supervisors_Hours_Pieces[Shift]
			RETURN
			IF (
			    Fct_Supervisors_Hours_Pieces[PPH_Type] IN {"Loading","Picking"},
			    CALCULATE (
			        SUM ( Fct_Supervisors_Hours_Pieces[Transaction_Pieces] ),
			        FILTER (
			            ALL ( Fct_Supervisors_Hours_Pieces ),
			            Fct_Supervisors_Hours_Pieces[Date] = d
			                && Fct_Supervisors_Hours_Pieces[PPH_Type] = "Loading"
			                && Fct_Supervisors_Hours_Pieces[Shift] = s
			        )
			    ),
			    0
			)
			
			```
		formatString: #,0
		lineageTag: 146204a1-50b0-4699-b373-0e20bd4f2e3a
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

