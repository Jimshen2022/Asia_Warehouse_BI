		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column '1_All in PPH Shipping' = DIVIDE('Fct_Supervisors_Hours_Pieces'[1_All in PPH Shipping Pieces],'Fct_Supervisors_Hours_Pieces'[1_All in PPH Shipping Hours])
		formatString: 0.0
		lineageTag: dc8c69a7-a35f-473c-b72f-40b7cfd2e5ee
