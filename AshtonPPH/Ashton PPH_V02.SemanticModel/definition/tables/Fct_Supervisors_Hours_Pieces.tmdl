	column Transaction_Pieces = ```
			
			CALCULATE(
			    SUM('Fact_Transactions'[pieces]),
			    FILTER(
			        ALL('Fact_Transactions'),  -- 清除 Fact_Transactions 表的上下文
			        'Fact_Transactions'[shift_date] = 'Fct_Supervisors_Hours_Pieces'[Date] &&
			        'Fact_Transactions'[employee_id] = 'Fct_Supervisors_Hours_Pieces'[Employee_ID] &&
			        'Fact_Transactions'[pph_type] = 'Fct_Supervisors_Hours_Pieces'[PPH_Type] && 
			        'Fact_Transactions'[product_category] = 'Fct_Supervisors_Hours_Pieces'[product_category] 
			    )
			)
			```
		formatString: #,0
		lineageTag: 721fa5a9-8864-4867-a5b9-568f0fb4fa03
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column Group_Date_Team_Avg_Transaction_Pieces = ```
			
			VAR CurrentTeam = 'Fct_Supervisors_Hours_Pieces'[Team]
			VAR CurrentPPHType = 'Fct_Supervisors_Hours_Pieces'[PPH_Type]
			VAR AvgValue = 
			    IF(
			        NOT(ISBLANK(CurrentTeam)) && CurrentTeam <> "0" && NOT(ISBLANK(CurrentPPHType)),
			        CALCULATE(
			            DIVIDE(
			                SUM('Fct_Supervisors_Hours_Pieces'[Transaction_Pieces]),
			                COUNTROWS('Fct_Supervisors_Hours_Pieces')
			            ),
			            ALLEXCEPT('Fct_Supervisors_Hours_Pieces', 'Fct_Supervisors_Hours_Pieces'[Group],'Fct_Supervisors_Hours_Pieces'[Date], 'Fct_Supervisors_Hours_Pieces'[Team])
			        ),
			        'Fct_Supervisors_Hours_Pieces'[Transaction_Pieces]
			    )
			RETURN
			    AvgValue
			
			```
		formatString: #,0
		lineageTag: 4453e471-fc63-4f9c-bc9b-359834ea5cb7
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column Group_Date_Team_Avg_Hrs = ```
			
			VAR CurrentTeam = 'Fct_Supervisors_Hours_Pieces'[Team]
			VAR CurrentPPHType = Fct_Supervisors_Hours_Pieces[PPH_Type]
			VAR AvgValue = 
			    IF(
			        NOT(ISBLANK(CurrentTeam)) && CurrentTeam <> "0" && NOT(ISBLANK(CurrentPPHType)),
			        CALCULATE(
			            DIVIDE(
			                SUM(Fct_Supervisors_Hours_Pieces[Final_Hrs_Individual]),
			                COUNTROWS(Fct_Supervisors_Hours_Pieces)
			            ),
			            ALLEXCEPT(Fct_Supervisors_Hours_Pieces,'Fct_Supervisors_Hours_Pieces'[Group], Fct_Supervisors_Hours_Pieces[Date], Fct_Supervisors_Hours_Pieces[Team])
			        ),
			        Fct_Supervisors_Hours_Pieces[Final_Hrs_Individual]
			    )
			RETURN
			    AvgValue
			```
		formatString: #,0.0
		lineageTag: 2816c4d4-8d12-4b84-bce0-f48852061bcd
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column Group_Date_Transaction_Pieces_Sum = ```
			
			CALCULATE(
			    SUM(Fct_Supervisors_Hours_Pieces[Transaction_Pieces]),
			    ALLEXCEPT(Fct_Supervisors_Hours_Pieces, Fct_Supervisors_Hours_Pieces[Group], Fct_Supervisors_Hours_Pieces[Date])
			)
			
			```
		formatString: #,0
		lineageTag: 04deb2e3-c764-4cbe-aca4-da8728a94659
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column Group_Date_Hrs_Sum = ```
			
			CALCULATE(
			    SUM(Fct_Supervisors_Hours_Pieces[Final_Hrs_All_In]),
			    ALLEXCEPT(Fct_Supervisors_Hours_Pieces, Fct_Supervisors_Hours_Pieces[Group], Fct_Supervisors_Hours_Pieces[Date])
			)
			
			```
		lineageTag: 5197b7fa-2fc0-4083-a2f3-63c3e953a95b
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

