	column Date2_Trx_Sum_Putaway_Unload_Hours = ```
			
			VAR d = Fct_Supervisors_Hours_Pieces[Date]
			VAR s = Fct_Supervisors_Hours_Pieces[Shift]
			VAR IsRowOK =
			    LEFT(Fct_Supervisors_Hours_Pieces[Group], 2) = "CG"
			        && Fct_Supervisors_Hours_Pieces[PPH_Type] IN {
			            "Picking-SCOOP","Put away","Replenishment","Unloading"
			        }
			RETURN
			IF (
			    IsRowOK,
			    CALCULATE (
			        SUM ( Fct_Supervisors_Hours_Pieces[Final_Hrs_All_In] ),
			        FILTER (
			            ALL ( Fct_Supervisors_Hours_Pieces ),
			            Fct_Supervisors_Hours_Pieces[Date] = d
			                && LEFT ( Fct_Supervisors_Hours_Pieces[Group], 2 ) = "CG"
			                && Fct_Supervisors_Hours_Pieces[PPH_Type] IN {
			                    "Picking-SCOOP","Put away","Replenishment","Unloading"
			                }
			                 && Fct_Supervisors_Hours_Pieces[Shift] = s
			        )
			    ),
			    0
			)
			
			```
		formatString: 0.0
		lineageTag: e7f12952-b568-4b74-99a5-9a4481dae3d0
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

