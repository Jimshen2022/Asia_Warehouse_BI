	partition Fct_All_Details_Rows_Summary = calculated
		mode: import
		source = ```
				
				VAR BaseRows =
				    SUMMARIZECOLUMNS(
				        'Dim_Calendar'[Date],            -- 日期
				        'Dim_Employee_'[Employee_ID],     -- 员工ID
				        'Dim_Employee_'[Employee_Name],   -- 员工姓名
				        'Dim_Position'[Position],         -- 职位
				        'Dim_Shift'[Shift],
				        'Dim_Metric'[MetricName]          -- 指标名称
				    )
				VAR AddMeasures =
				    ADDCOLUMNS(
				        BaseRows,
				        "PPH Metric Value", [PPH Metric Value],  
				        "Goal",              [Goal],
				        "Achievement%",      [Achievement%]
				    )
				RETURN
				    FILTER(
				        AddMeasures,
				        NOT ISBLANK ( [PPH Metric Value] )   -- 只保留 metric value 有值的行
				         && NOT CONTAINSSTRING ( 'Dim_Metric'[MetricName], "All in" )
				    )
				
				
				```

	annotation PBI_Id = 9c9b412d213e41229a1341167ea7981e

