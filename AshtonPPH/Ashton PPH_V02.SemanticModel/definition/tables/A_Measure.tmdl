			    color: #1e90ff;
			    margin-bottom: 16px;
			    text-align: center;
			  }
			
			  .pph-row {
			    display: flex;
			    gap: 32px;
			  }
			
			  .pph-card {
			    width: 320px;
			    height: 150px;
			    border-radius: 32px;
			    display: flex;
			    align-items: center;
			    justify-content: center;
			    color: #ffffff;
			    font-size: 26px;
			    font-weight: 700;
			    letter-spacing: 0.5px;
			    cursor: default;
			    box-shadow: 0 4px 10px rgba(0,0,0,0.25);
			    transition: transform 0.25s ease, box-shadow 0.25s ease;
			  }
			
			  .pph-card:hover {
			    transform: translateY(-6px) scale(1.03);
			    box-shadow: 0 10px 24px rgba(0,0,0,0.35);
