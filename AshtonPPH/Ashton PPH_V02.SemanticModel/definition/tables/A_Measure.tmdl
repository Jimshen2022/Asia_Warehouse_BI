	measure 'PPH Metric Value' =
			
			VAR m =
			    SELECTEDVALUE ( Dim_Metric[MetricName] )
			RETURN
			    SWITCH (
			        TRUE (),
			        m = "1_All in PPH Shipping", [1_All in PPH Shipping],
			        m = "2_All in PPH CG Receiving", [2_All in PPH CG Receiving],
			        m = "3_All in PPH Unload UPH", [3_All in PPH Unload UPH],
			        m = "I01_Individual Loading PPH", [I01_Individual Loading PPH],
			        m = "I02_Individual Picking PPH", [I02_Individual Picking PPH],
			        m = "I03_Individual CG Unload PPH", [I03_Individual CG Unload PPH],
			        m = "I04_Individual UPH Unload PPH", [I04_Individual UPH Unload PPH],
			        m = "I05_Individual CG Putaway PPH", [I05_Individual CG Putaway PPH],
			        m = "I06_Individual UPH Putaway PPH", [I06_Individual UPH Putaway PPH],
			        BLANK ()
			    )
		displayFolder: 00_Achievement
		lineageTag: 01a314c9-f091-495c-b3e3-85e5cda12a96

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '0_LastWeek Sun-Sat Flag' =
			
			VAR _utc = 7 / 24
			VAR _today =
			    INT ( TODAY () + _utc ) -- 今天（按越南时区）
			VAR _currSun =
			    _today - WEEKDAY ( _today, 1 ) + 1 -- 本周周日
			VAR _start = _currSun - 7 -- 上周周日
			VAR _end = _start + 6 -- 上周周六
			VAR d =
			    SELECTEDVALUE ( 'Dim_Calendar'[Date] )
			RETURN
			    IF ( NOT ISBLANK ( d ) && d >= _start && d <= _end, 1, 0 )
		formatString: 0
		lineageTag: 9e16882b-42ae-48ce-95d5-5bdc0e6bb467

	measure '1_All in PPH Shipping (Daily, NoDims)' =
			
			//-- ① 每日 PPH（去掉 Group / Shift / Employee 等维度，只按日期算）
			CALCULATE (
			    [1_All in PPH Shipping],
			    -- 你原来的度量：Pieces ÷ Hours
			    REMOVEFILTERS ( 'Dim_Group' ),
			    REMOVEFILTERS ( 'Dim_Team' ),
			    REMOVEFILTERS ( 'Dim_Shift' ),
			    REMOVEFILTERS ( 'Dim_Employee_' ),
			    REMOVEFILTERS ( 'Dim_PPH_Type' )
			)
		displayFolder: 1_All in PPH Shipping
		lineageTag: cc6e319d-e42d-4562-9ac6-90beef1b29fd

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '1_All in PPH Shipping UCL (Dynamic)' =
			
			VAR _CL = [1_All in PPH Shipping CL (Dynamic)]
			VAR _Sigma = [1_All in PPH Shipping Sigma (Dynamic)]
			RETURN
			    IF ( NOT ISBLANK ( _CL ) && NOT ISBLANK ( _Sigma ), _CL + 3 * _Sigma )
		displayFolder: 1_All in PPH Shipping
		lineageTag: 4fc46157-e87b-475f-a7c0-0a646af0f9ef

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '1_All in PPH Shipping LCL (Dynamic)' =
			
			VAR _CL = [1_All in PPH Shipping CL (Dynamic)]
			VAR _Sigma = [1_All in PPH Shipping Sigma (Dynamic)]
			RETURN
			    IF (
			        NOT ISBLANK ( _CL ) && NOT ISBLANK ( _Sigma ),
			        MAX ( 0, _CL - 3 * _Sigma ) -- 不要小于 0
			    )
		displayFolder: 1_All in PPH Shipping
		lineageTag: 36824a52-f8ff-4b33-90a3-855d36204a5f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '2_All in PPH CG Receiving (Daily, NoDims)' =
			
			//-- ① 每日 PPH（去掉 Group / Shift / Employee 等维度，只按日期算）
			CALCULATE (
			    [2_All in PPH CG Receiving],
			    -- 你原来的度量：Pieces ÷ Hours
			    REMOVEFILTERS ( 'Dim_Group' ),
			    REMOVEFILTERS ( 'Dim_Team' ),
			    REMOVEFILTERS ( 'Dim_Shift' ),
			    REMOVEFILTERS ( 'Dim_Employee_' ),
			    REMOVEFILTERS ( 'Dim_PPH_Type' )
			)
		displayFolder: 2_All in PPH CG Receiving
		lineageTag: ec2d0bc2-db53-4d04-8915-da21b9c89acb

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '2_All in PPH CG Receiving CL (Dynamic)' =
			
			VAR DateWindow = ALLSELECTED ( 'Dim_Calendar'[Date] ) -- 获取切片器选中的日期集合
			RETURN
			    CALCULATE (
			        AVERAGEX (
			            VALUES ( 'Dim_Calendar'[Date] ),
			            [2_All in PPH CG Receiving (Daily, NoDims)]
			                    ),
			        DateWindow
			    )
		displayFolder: 2_All in PPH CG Receiving
		lineageTag: d137bb9b-5992-4f54-92b7-66bd4e50b578

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '2_All in PPH CG Receiving Sigma (Dynamic)' =
			
			VAR DateWindow = ALLSELECTED ( 'Dim_Calendar'[Date] )
			RETURN
			    CALCULATE (
			        STDEVX.P ( -- 使用总体标准差
			            VALUES ( 'Dim_Calendar'[Date] ),
			            [2_All in PPH CG Receiving (Daily, NoDims)]
			        ),
			        DateWindow
			    )
		displayFolder: 2_All in PPH CG Receiving
		lineageTag: 02982a7e-bf12-4612-9d62-5a8956ee9cfe

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '2_All in PPH CG Receiving LCL' =
			
			VAR _CL = [2_All in PPH CG Receiving CL (Dynamic)]
			VAR _Sigma = [2_All in PPH CG Receiving Sigma (Dynamic)]
			RETURN
			    IF (
			        NOT ISBLANK ( _CL ) && NOT ISBLANK ( _Sigma ),
