			    IF ( NOT ISBLANK ( _r ) && _r <= 5, 1 )
		formatString: 0
		displayFolder: 01_Rank
		lineageTag: 3e8a64f4-25a8-4dc8-94b4-227681cb79af

	measure 'Is Top5 Month' =
			
			VAR _r = [Rank Month by Achievement]
			RETURN
			    IF ( NOT ISBLANK ( _r ) && _r <= 5, 1 )
		formatString: 0
		displayFolder: 01_Rank
		lineageTag: 036b67d1-05b4-4f07-817f-5a88603a617b

	measure 'Individual Achievement%' =
			
			DIVIDE ( [PPH Metric Value], -- 这里的 PPH 度量不要有 ALL('Dim_Employee_')
			    [Goal] )
		lineageTag: e2351690-8a84-410a-9efd-672c2b48ef97

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Week Avg Achievement%' =
			
			VAR currWeek =
			    SELECTEDVALUE ( 'Dim_Calendar'[WeekSaturday] )
			VAR currEmp =
			    SELECTEDVALUE ( 'Dim_Employee_'[Employee_ID] )
			RETURN
			    CALCULATE (
			        AVERAGE ( 'Fct_All_Details_Rows_Summary'[Achievement%] ),
			        KEEPFILTERS ( 'Dim_Calendar'[WeekSaturday] = currWeek ),
			        KEEPFILTERS ( 'Dim_Employee_'[Employee_ID] = currEmp )
			    )
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 00_Week_Rank
		lineageTag: 76c0e3c0-6a6b-46ef-9523-5f885940809d

	measure 'Week Rank' =
			
			VAR CurrentAvg = [Week Avg Achievement%] // 如果 Avg% 是列，请替换为 AVERAGE('Table'[Avg%])
			RETURN
			    IF (
			        // 1. 只有当 Avg% 不为空时才进行排名，避免显示无数据的员工
			        NOT ( ISBLANK ( CurrentAvg ) ),
			        RANKX (
			            // 2. ALL 函数：移除员工ID和姓名的筛选，但保留 WeekSaturday 的筛选
			            // 这样做的目的是获取当前周所有员工的列表
			            ALL (
			                Dim_Employee_[Employee_ID],
			                Dim_Employee_[employee_name]
			            ),
			            // 3. 排序依据：使用 Avg%
			            [Week Avg Achievement%],
			            ,
			            // 5. 排序方向：DESC 表示从大到小 (高的排第一)
			            DESC,
			            // 6. 排名方式：Dense 表示如果不连续（例如并列第一），下一个是第二名而不是第三名
			            DENSE
			        )
			    )
		formatString: 0
		displayFolder: 00_Week_Rank
		lineageTag: b8c7c808-52bd-4040-9d4c-4caaa0c59c7e

	measure 'Week Medal' =
			
			VAR _currentAvg = [Week Avg Achievement%] // 获取当前行的平均值
			VAR _rank = [Week Rank] // 获取你刚才写好的排名度量值
			RETURN
			    SWITCH (
			        TRUE (),
			        // 1. 安全检查：如果平均值为为空，或者排名为空，则不显示奖牌
			        ISBLANK ( _currentAvg ) || ISBLANK ( _rank ), BLANK (),
			        // 2. 根据排名分配奖牌
			        _rank = 1, "🥇",
			        _rank = 2, "🥈",
			        _rank = 3, "🥉",
			        // 3. 第4名及以后不显示任何内容
			        BLANK ()
			    )
		displayFolder: 00_Week_Rank
		lineageTag: 6ac59d51-3a3e-4129-805d-5823f5609cef

	measure 'Month Avg Achievement%' =
			
			VAR currMonth =
			    SELECTEDVALUE ( 'Dim_Calendar'[YearMonth] )
			VAR currEmp =
			    SELECTEDVALUE ( 'Dim_Employee_'[Employee_ID] )
			RETURN
			    CALCULATE (
			        AVERAGE ( 'Fct_All_Details_Rows_Summary'[Achievement%] ),
			        KEEPFILTERS ( 'Dim_Calendar'[YearMonth] = currMonth ),
			        KEEPFILTERS ( 'Dim_Employee_'[Employee_ID] = currEmp )
			    )
		formatString: #,0.00%;-#,0.00%;#,0.00%
		displayFolder: 00_Month_Rank
		lineageTag: 814cd1a6-af8d-4665-a066-433870c995be

	measure 'Medal by AVG% (Big)' =
			
