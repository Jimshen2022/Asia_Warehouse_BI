			VAR _icon =
			    SWITCH ( _rank, 1, "🥇", 2, "🥈", 3, "🥉" )
			RETURN
			    IF (
			        NOT ISBLANK ( _icon ),
			        "data:image/svg+xml;utf8, " & "<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'>" & "<text x='25' y='45' font-size='90' text-anchor='middle'>" & _icon & "</text>" & "</svg>"
			    )
		displayFolder: 00_Week_Rank
		lineageTag: d235c3d4-b6fa-4841-b390-12735f51bdea
		dataCategory: ImageUrl

	measure 'Medal by AVG% (Adjusted)' =
			
			VAR _rank = [Week Rank]
			VAR _icon =
			    SWITCH ( _rank, 1, "🥇", 2, "🥈", 3, "🥉" )
			RETURN
			    IF (
			        NOT ISBLANK ( _icon ),
			        "data:image/svg+xml;utf8, " & "<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'>" & // 建议 y 值调整到 75 左右，使图标在单元格内垂直居中
			        "<text x='50' y='45' font-size='35' text-anchor='middle'>" & _icon & "</text>" & "</svg>"
			    )
		displayFolder: 00_Week_Rank
		lineageTag: 2dfe71ef-defc-49e5-be79-17b04ff49e27
		dataCategory: ImageUrl

	measure 'Employee Week Position' =
			
			VAR _week =
			    SELECTEDVALUE ( 'Dim_Calendar'[WeekSaturday] )
			VAR _empID =
			    SELECTEDVALUE ( 'Dim_Employee_'[Employee_ID] )
			VAR _empName =
			    SELECTEDVALUE ( 'Dim_Employee_'[Employee_Name] ) -- 先算这一周这个员工的 Week Achievement% Avg.
			VAR _achv =
			    CALCULATE (
			        [Week Avg Achievement%],
			        'Dim_Calendar'[WeekSaturday] = _week,
			        'Dim_Employee_'[Employee_ID] = _empID
			    )
			RETURN
			    IF (
			        -- 只有 Week Achievement% Avg. > 0 的行才显示
			        _achv > 0,
			        CONCATENATEX (
			            CALCULATETABLE (
			                DISTINCT ( 'Fct_All_Details_Rows_Summary'[Position] ),
			                'Dim_Calendar'[WeekSaturday] = _week,
			                'Dim_Employee_'[Employee_ID] = _empID,
			                'Dim_Employee_'[Employee_Name] = _empName
			            ),
			            'Fct_All_Details_Rows_Summary'[Position],
			            ", ",
			            'Fct_All_Details_Rows_Summary'[Position], ASC
			        )
			    )
		displayFolder: 00_Week_Rank
		lineageTag: 52e73d2b-f8f4-4ffa-9358-92411d05ffdb

