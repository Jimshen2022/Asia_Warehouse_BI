	measure Achievement% =
			
			DIVIDE ( 'A_Measure'[PPH Metric Value], 'A_Measure'[Goal] )
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 00_Achievement
		lineageTag: d3c133ef-5e5f-4c64-a5b2-35ec3fb58f8d

	measure Goal =
			
			CALCULATE ( SUM ( 'Fct_metrics_goal'[Goal] ) )
		formatString: 0
		displayFolder: 00_Achievement
		lineageTag: 4bfe9ff5-d770-4642-8d0c-5b456c1d7eb7

	measure 'Achievement% (Last 3 Months)' =
			
			CALCULATE (
			    [Achievement%],
			    DATESINPERIOD ( 'Dim_Calendar'[Date], MAX ( 'Dim_Calendar'[Date] ), -3, MONTH )
			)
		displayFolder: 00_Achievement
		lineageTag: 119d8f96-fb9f-4e2d-8e0b-6db775abadba

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Rank Week by Achievement' =
			
			VAR _metric =
			    SELECTEDVALUE ( 'Fct_All_Details_Rows_Summary'[MetricName] )
			VAR _week =
			    SELECTEDVALUE ( 'Dim_Calendar'[YearWeek] )
			RETURN
			    IF (
			        ISBLANK ( [Achievement%] ),
			        BLANK (),
			        RANKX (
			            FILTER (
			                ALL ( 'Fct_All_Details_Rows_Summary' ),
			                'Fct_All_Details_Rows_Summary'[MetricName] = _metric
			                    && RELATED ( 'Dim_Calendar'[YearWeek] ) = _week
			            ),
			            CALCULATE ( [Achievement%] ),
			            ,
			            DESC,
			            DENSE
			        )
			    )
		formatString: 0
		displayFolder: 01_Rank
		lineageTag: 83b3285d-5667-4aa5-ba93-1f00088df1c3

	measure 'Rank Month by Achievement' =
			
			VAR _metric =
			    SELECTEDVALUE ( 'Fct_All_Details_Rows_Summary'[MetricName] )
			VAR _yearMonth =
			    SELECTEDVALUE ( 'Dim_Calendar'[YearMonth] )
			RETURN
			    IF (
			        ISBLANK ( [Achievement%] ),
			        BLANK (),
			        RANKX (
			            FILTER (
			                ALL ( 'Fct_All_Details_Rows_Summary' ),
			                'Fct_All_Details_Rows_Summary'[MetricName] = _metric
			                    && RELATED ( 'Dim_Calendar'[YearMonth] ) = _yearMonth
			            ),
			            CALCULATE ( [Achievement%] ),
			            ,
			            DESC,
			            DENSE
			        )
			    )
		formatString: 0
		displayFolder: 01_Rank
