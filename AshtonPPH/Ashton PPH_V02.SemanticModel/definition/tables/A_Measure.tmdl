	measure '1_All in PPH Shipping CL (Dynamic)' =
			
			VAR DateWindow = ALLSELECTED ( 'Dim_Calendar'[Date] ) -- 获取切片器选中的日期集合
			RETURN
			    CALCULATE (
			        AVERAGEX (
			            VALUES ( 'Dim_Calendar'[Date] ),
			            [1_All in PPH Shipping (Daily, NoDims)]
			        ),
			        DateWindow
			    )
		displayFolder: 1_All in PPH Shipping
		lineageTag: 4118b78c-78a9-4f86-9480-5a389ac0079a

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '1_All in PPH Shipping Sigma (Dynamic)' =
			
			VAR DateWindow = ALLSELECTED ( 'Dim_Calendar'[Date] )
			RETURN
			    CALCULATE (
			        STDEVX.P ( -- 使用总体标准差
			            VALUES ( 'Dim_Calendar'[Date] ),
			            [1_All in PPH Shipping (Daily, NoDims)]
			        ),
			        DateWindow
			    )
		displayFolder: 1_All in PPH Shipping
		lineageTag: 7105b421-e415-423f-a46a-4ddca1c620f1

		annotation PBI_FormatHint = {"isGeneralNumber":true}

