			  .pph-orange { background: #e76f2f; }      /* All in PPH */
			  .pph-black  { background: #000000; }      /* Individual */
			  .pph-green  { background: #004b45; }      /* Weekly */
			  .pph-blue   { background: #004f9e; }      /* Monthly */
			
			  /* --- small buttons area --- */
			  .pph-small-row {
			    margin-top: 32px;
			    display: flex;
			    gap: 24px;
			  }
			
			  .pph-small-btn {
			    min-width: 190px;
			    padding: 10px 24px;
			    border-radius: 12px;
			    font-size: 14px;
			    font-weight: 600;
			    letter-spacing: 0.05em;
