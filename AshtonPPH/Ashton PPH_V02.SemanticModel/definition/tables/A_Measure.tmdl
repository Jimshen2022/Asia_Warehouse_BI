	measure Notice = ```
			
			// Define the SVG wrapper and MIME type required by Power BI
			VAR Prefix = "data:image/svg+xml;utf8,"
			
			// Build the SVG XML structure
			//     <text x='15' y='35' font-family='Segoe UI, Arial' font-size='18' font-weight='bold' fill='black'>Notice:</text>
			VAR SvgContent = 
			"<svg xmlns='http://www.w3.org/2000/svg' width='300' height='80'>
			    <rect width='100%' height='100%' fill='white' stroke='lightgray' stroke-width='1' rx='8' />
			    
			
			    
			    <text x='15' y='15' font-family='Segoe UI, Arial' font-size='18' fill='black'>Team begin with:</text>
			    
			    <text x='30' y='45' font-family='Segoe UI, Arial' font-size='16' fill='black'>• RM* --- work hours &lt; 5 hours</text>
			    <text x='30' y='70' font-family='Segoe UI, Arial' font-size='16' fill='black'>• SP* --- Supporting people</text>
			</svg>"
			
			RETURN Prefix & SvgContent
			```
		lineageTag: 6a703181-8669-4ad5-a8ab-0ca172d41fd3
		dataCategory: ImageUrl

