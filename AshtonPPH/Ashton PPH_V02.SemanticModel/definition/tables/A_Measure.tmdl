			    background: #a8e6a3;
			    color: #275b24;
			  }
			
			  .pph-small-download {
			    background: #00a36c;
			    color: #ffffff;
			    border: 2px solid #00d89e;
			    animation: glow 2.5s ease-in-out infinite;
			  }
			
			  @keyframes glow {
			    0%   { box-shadow: 0 0 0 rgba(0, 255, 170, 0.15); }
			    50%  { box-shadow: 0 0 8px rgba(0, 255, 170, 0.35),
			                     0 0 16px rgba(0, 255, 170, 0.25); }
