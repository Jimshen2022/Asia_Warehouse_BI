	measure 'Week Avg Achievement% (Total as Average)' =
			
			VAR _isEmployeeRow =
			    ISINSCOPE ( 'Dim_Employee_'[Employee_ID] )
			RETURN
			    IF (
			        -- 行级：按员工显示原来的值
			        _isEmployeeRow,
			        [Week Avg Achievement%],
			        -- Total 行：对当前筛选下所有员工的周达成率再取平均
			        AVERAGEX (
			            VALUES ( 'Dim_Employee_'[Employee_ID] ),
			            [Week Avg Achievement%]
			        )
			    )
		formatString: #,0.0%;-#,0.0%;#,0.0%
		displayFolder: 00_Week_Rank
