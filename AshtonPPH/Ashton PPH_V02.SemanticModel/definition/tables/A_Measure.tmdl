	measure Html_Navigate_Pro = ```
			
			"
			<style>
			  body {
			    margin: 0;
			    font-family: 'Segoe UI', Arial, sans-serif;
			    background: #4a4f58;
			  }
			
			  .nav-shell {
			    display: flex;
			    justify-content: center;
			    align-items: center;
			    padding: 32px 24px;
			  }
			
			  .nav-wrapper {
			    width: 880px;
			    max-width: 100%;
			    display: flex;
			    flex-direction: column;
			    align-items: center;
			    gap: 28px;
			  }
			
			  .nav-title {
			    width: 100%;
			    display: flex;
			    justify-content: space-between;
			    align-items: baseline;
			  }
			
			  .nav-title-main {
			    font-size: 34px;
			    font-weight: 800;
			    color: #1ec0ff;
			    letter-spacing: 0.04em;
			  }
			
			  .nav-title-sub {
			    font-size: 12px;
			    text-transform: uppercase;
			    letter-spacing: 0.18em;
			    color: rgba(255,255,255,0.7);
			  }
			
			  .nav-grid {
			    width: 100%;
			    display: grid;
			    grid-template-columns: repeat(2, minmax(0,1fr));
			    gap: 22px 28px;
			  }
			
			  .nav-card {
			    position: relative;
			    border-radius: 26px;
			    padding: 20px 26px;
			    color: #ffffff;
			    box-shadow: 0 8px 20px rgba(0,0,0,0.35);
			    overflow: hidden;
			    cursor: default;
			    transition: transform 0.25s ease, box-shadow 0.25s ease;
			  }
			
			  .nav-card::before {
			    content: '';
			    position: absolute;
			    left: 0;
			    top: 0;
			    width: 6px;
			    height: 100%;
			    opacity: 0.7;
			  }
			
			  .nav-card:hover {
			    transform: translateY(-5px);
			    box-shadow: 0 14px 30px rgba(0,0,0,0.45);
			  }
			
			  .nav-card-title {
			    font-size: 22px;
			    font-weight: 700;
			    margin-bottom: 4px;
			  }
			
			  .nav-card-desc {
			    font-size: 12px;
			    opacity: 0.85;
			  }
			
			  /* 颜色方案：左列偏运营，右列偏个人 & 排名 */
			  .nav-all {
			    background: linear-gradient(135deg, #f28b3b 0%, #d45a19 100%);
			  }
			  .nav-all::before { background: #ffdfb4; }
			
			  .nav-ind {
			    background: linear-gradient(135deg, #151515 0%, #262626 100%);
			  }
			  .nav-ind::before { background: #ffc65c; }
			
			  .nav-week {
			    background: linear-gradient(135deg, #00534c 0%, #00846e 100%);
			  }
			  .nav-week::before { background: #9fffe3; }
			
			  .nav-month {
			    background: linear-gradient(135deg, #004b9e 0%, #0076ce 100%);
			  }
			  .nav-month::before { background: #b7daff; }
			
			  /* 底部小按钮区 */
			  .nav-bottom-row {
			    margin-top: 10px;
			    width: 100%;
			    display: flex;
			    justify-content: center;
			    gap: 20px;
			  }
			
			  .nav-pill {
			    min-width: 220px;
			    padding: 12px 24px;
			    border-radius: 999px;
			    font-size: 13px;
			    font-weight: 600;
			    letter-spacing: 0.12em;
			    text-transform: uppercase;
			    display: flex;
			    align-items: center;
			    justify-content: center;
			    cursor: default;
			    box-shadow: 0 6px 14px rgba(0,0,0,0.35);
			    transition: transform 0.22s ease, box-shadow 0.22s ease;
			  }
			
			  .nav-pill:hover {
			    transform: translateY(-3px);
			    box-shadow: 0 10px 20px rgba(0,0,0,0.45);
			  }
			
			  .nav-pill-goal {
			    background: #f0f4f2;
			    color: #264b3c;
			  }
			
			  .nav-pill-download {
			    background: linear-gradient(135deg, #00a36c 0%, #00c99a 100%);
			    color: #ffffff;
			    position: relative;
			  }
			
			  .nav-pill-download::after {
			    content: '';
			    position: absolute;
			    inset: -2px;
			    border-radius: inherit;
			    border: 1px solid rgba(255,255,255,0.45);
			    opacity: 0;
			    transition: opacity 0.25s ease;
			  }
			
			  .nav-pill-download:hover::after {
			    opacity: 1;
			  }
